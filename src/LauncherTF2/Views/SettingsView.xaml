<UserControl x:Class="LauncherTF2.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:core="clr-namespace:LauncherTF2.Core"
             xmlns:settings="clr-namespace:LauncherTF2.Models.Settings"
             xmlns:vm="clr-namespace:LauncherTF2.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1030">

    <UserControl.Resources>
        <!-- ═══════════════════════════════════════════════════════════════════
             Theme-driven primitives. EVERY brush/foreground here resolves
             through DynamicResource so the live theme can swap them at runtime.
             Adding a new control style? Mirror this pattern — never hardcode a
             hex color in a Setter.
             ═══════════════════════════════════════════════════════════════════ -->

        <!-- Toggle switch -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent" Cursor="Hand">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Border x:Name="SwitchTrack" Grid.Column="1" Width="40" Height="20" Background="{DynamicResource SurfaceInsetBrush}" CornerRadius="10" Margin="10,0,0,0">
                                <Ellipse x:Name="SwitchKnob" Width="14" Height="14" Fill="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Left" Margin="3,0">
                                    <Ellipse.RenderTransform><TranslateTransform x:Name="KnobTransform" X="0"/></Ellipse.RenderTransform>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="SwitchKnob" Property="Fill" Value="White"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobTransform" Storyboard.TargetProperty="X" To="20" Duration="0:0:0.15" DecelerationRatio="0.5"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobTransform" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.15" DecelerationRatio="0.5"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Sidebar nav button — bound to SidebarEntry.IsActive for the active highlight. -->
        <Style x:Key="SidebarEntryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="DescStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,-2,0,6"/>
            <Setter Property="Opacity" Value="0.75"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border Grid.ColumnSpan="2" CornerRadius="4" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                <Path Grid.Column="1" Fill="{DynamicResource TextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L0,2 L4,6 L8,2 L8,0 L4,4 z"/>
            </Grid>
        </ControlTemplate>
        <ControlTemplate x:Key="ComboBoxTextBox" TargetType="TextBox">
            <Border x:Name="PART_ContentHost" Focusable="False" Background="{TemplateBinding Background}"/>
        </ControlTemplate>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton Template="{StaticResource ComboBoxToggleButton}" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press"/>
                            <ContentPresenter IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" Margin="8,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <TextBox x:Name="PART_EditableTextBox" Style="{x:Null}" Template="{StaticResource ComboBoxTextBox}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,3,23,3" Focusable="True" Background="#00000000" Foreground="{DynamicResource TextBrush}" Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="{DynamicResource SurfaceAltBrush}" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="4"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SliderThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Ellipse x:Name="E" Fill="{DynamicResource TextBrush}" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1" Width="16" Height="16"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="E" Property="Fill" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type Slider}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="1" Height="4" Background="{DynamicResource BorderBrush}" CornerRadius="2" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Background="{DynamicResource AccentBrush}" Height="4" BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="2" Height="4"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumbStyle}" VerticalAlignment="Center"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════════════
             Per-item DataTemplates — one row per SettingItem subtype. Adding a
             new SettingItem variant means: new C# class + new DataTemplate +
             register it in the ItemsControl below. No XAML edits required to
             add a new *instance* of an existing type.
             ═══════════════════════════════════════════════════════════════════ -->

        <!-- Reusable row-disabled style. Binds the SettingItem.IsEnabled flag to
             both IsEnabled (blocks input) and Opacity (dims). Used by every
             schema row so child settings (e.g. Medic autocall threshold) look
             clearly inactive when their parent toggle is off. -->
        <Style x:Key="SettingRowStyle" TargetType="FrameworkElement">
            <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Inline "sv_pure" badge — rendered next to titles for settings whose
             cvars are blocked on Casual / sv_pure community servers. Theme-aware:
             chip background is SurfaceAltBrush, text is AccentBrush. -->
        <DataTemplate x:Key="NotCasualChipTemplate">
            <Border Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                    CornerRadius="3" Padding="6,1" Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    ToolTip="This cvar is blocked on sv_pure (Casual) servers and only takes effect on community servers that allow it.">
                <TextBlock Text="not casual compatible" Foreground="{DynamicResource AccentBrush}"
                           FontSize="9" FontWeight="SemiBold"/>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type settings:ToggleSetting}">
            <Grid Margin="0,6,0,6" Style="{StaticResource SettingRowStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                        <ContentControl ContentTemplate="{StaticResource NotCasualChipTemplate}"
                                        Visibility="{Binding NotCasualCompatible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Description}" Style="{StaticResource DescStyle}"
                               Visibility="{Binding Description, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                </StackPanel>
                <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"
                          IsChecked="{Binding IsOn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type settings:SliderSetting}">
            <StackPanel Margin="0,8,0,8" Style="{StaticResource SettingRowStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Right" Text="{Binding DisplayValue}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Width="80" TextAlignment="Right"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                        <ContentControl ContentTemplate="{StaticResource NotCasualChipTemplate}"
                                        Visibility="{Binding NotCasualCompatible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                </DockPanel>
                <TextBlock Text="{Binding Description}" Style="{StaticResource DescStyle}"
                           Visibility="{Binding Description, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                <Slider Minimum="{Binding Min}" Maximum="{Binding Max}"
                        Value="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TickFrequency="{Binding Step}"
                        IsSnapToTickEnabled="{Binding IsInteger}"
                        Margin="0,4,0,0"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="{x:Type settings:ChoiceSetting}">
            <Grid Margin="0,6,0,6" Style="{StaticResource SettingRowStyle}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextBrush}" FontSize="13"/>
                        <ContentControl ContentTemplate="{StaticResource NotCasualChipTemplate}"
                                        Visibility="{Binding NotCasualCompatible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding Description}" Style="{StaticResource DescStyle}"
                               Visibility="{Binding Description, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                </StackPanel>
                <!-- Explicit ItemTemplate + SelectionBoxItemTemplate would normally
                     show the Label. Our custom ComboBox ControlTemplate uses
                     ContentPresenter with TemplateBinding SelectionBoxItem which
                     calls ToString() on the data item — ChoiceOption overrides
                     ToString to return Label, so the dropdown reads cleanly. -->
                <ComboBox Grid.Column="1" Width="160" Height="28" VerticalAlignment="Center"
                          ItemsSource="{Binding Options}"
                          SelectedItem="{Binding Selected, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextBrush}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
        </DataTemplate>


        <!-- One full category panel — a Border + nested ItemsControl of its items. -->
        <DataTemplate DataType="{x:Type settings:SettingCategory}">
            <StackPanel core:ScrollAnchor.Name="{Binding Id}" core:ScrollAnchor.Host="{Binding ElementName=ContentScroller}" Margin="0,0,0,30">
                <TextBlock Text="{Binding Title}" Style="{StaticResource SectionHeaderStyle}" FontSize="20"/>
                <TextBlock Text="{Binding Description}" Style="{StaticResource DescStyle}" Margin="0,-8,0,12"/>
                <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="18">
                    <ItemsControl ItemsSource="{Binding Items}"/>
                </Border>
            </StackPanel>
        </DataTemplate>

    </UserControl.Resources>

    <Grid Background="{DynamicResource PageBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═════════ Data-driven sidebar ═════════ -->
        <Border Background="{DynamicResource SurfaceInsetBrush}" Padding="12,20">
            <DockPanel>
                <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="4,0,0,20" DockPanel.Dock="Top"/>
                <Button Content="Reset all" Command="{Binding ResetCommand}" Style="{StaticResource ModernButtonStyle}" Background="#7e1f1f" Margin="0,30,0,0" HorizontalAlignment="Stretch" DockPanel.Dock="Bottom"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource ModernScrollViewerStyle}">
                    <ItemsControl ItemsSource="{Binding SidebarEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource SidebarEntryButtonStyle}"
                                        Content="{Binding Title}"
                                        Command="{Binding DataContext.NavigateCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═════════ Content ═════════ -->
        <ScrollViewer x:Name="ContentScroller" Grid.Column="1" VerticalScrollBarVisibility="Auto"
                      Style="{StaticResource ModernScrollViewerStyle}" Padding="30,20,30,20"
                      ScrollChanged="ContentScroller_ScrollChanged">
            <StackPanel>

                <!-- ─── General (fixed: TF2 path, display, launch options) ─── -->
                <StackPanel core:ScrollAnchor.Name="general" core:ScrollAnchor.Host="{Binding ElementName=ContentScroller}" Margin="0,0,0,30">
                    <TextBlock Text="General" Style="{StaticResource SectionHeaderStyle}" FontSize="20"/>

                    <Border Background="#1e4d8c" CornerRadius="8" Padding="14,10" Margin="0,0,0,12" Visibility="{Binding ShowProfileMigrationBanner, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="✕" Command="{Binding DismissMigrationBannerCommand}" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand" VerticalAlignment="Center" FontSize="16" Width="30" Height="30"/>
                            <StackPanel>
                                <TextBlock Text="We've upgraded to the new Profile system." Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                                <TextBlock Text="Your settings have been preserved. Choose a profile below, or keep your current settings." Foreground="#d0e2f5" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Profile" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableProfiles}" SelectedItem="{Binding SelectedProfile, Mode=TwoWay}" VerticalAlignment="Center" Height="34"/>
                                <Button Grid.Column="2" Content="Apply" Command="{Binding ApplyProfileCommand}" Style="{StaticResource ModernButtonStyle}" Background="{DynamicResource AccentBrush}" Foreground="White" Padding="20,0" Height="34"/>
                                <Button Grid.Column="4" Content="Manage Profiles..." Command="{Binding OpenProfileManagerCommand}" Style="{StaticResource ModernButtonStyle}" Background="{DynamicResource SurfaceInsetBrush}" Padding="16,0" Height="34"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentProfile}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <Ellipse Fill="#ef5350" Width="8" Height="8" Margin="0,0,6,0"/>
                                <TextBlock Text="Custom settings active" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="TF2 Installation Path" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Path to your tf folder (e.g. .../Team Fortress 2/tf)" Style="{StaticResource DescStyle}"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Browse" Command="{Binding BrowseFolderCommand}" Style="{StaticResource ModernButtonStyle}" Padding="14,8" Margin="8,0,0,0"/>
                                <TextBox Text="{Binding CurrentSettings.SteamPath, UpdateSourceTrigger=PropertyChanged}"/>
                            </DockPanel>
                            <TextBlock Text="{Binding PathValidationMessage}" FontSize="11" Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#ef5350"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPathValid}" Value="True">
                                                <Setter Property="Foreground" Value="#66bb6a"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Display" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding DisplayModes}" SelectedItem="{Binding DisplayMode}" Width="220" HorizontalAlignment="Left" Margin="0,0,0,12"/>

                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Width" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding CurrentSettings.Width}" TextAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Height" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding CurrentSettings.Height}" TextAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Refresh rate (Hz)" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding CurrentSettings.RefreshRate}" TextAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,12,0,0">
                                <TextBlock Text="Game FOV" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                                <DockPanel Margin="0,2,0,0">
                                    <TextBlock Text="{Binding ElementName=FovSlider, Path=Value}" DockPanel.Dock="Right" Width="30" TextAlignment="Right" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <Slider x:Name="FovSlider" Minimum="70" Maximum="90" Value="{Binding CurrentSettings.Fov}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                </DockPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Steam launch options" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Auto-synced from the toggles below. You can also append custom flags here &#x2014; the launcher won't touch them." Style="{StaticResource DescStyle}"/>
                            <TextBox Text="{Binding CurrentSettings.LaunchArgs, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Launch behavior" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>

                            <!-- DirectX version picker. Bound to DxLevelSelected on the VM —
                                 changes write to SettingsModel.DxLevel which flows into the
                                 -dxlevel N launch argument via SyncLaunchOptions. The combo
                                 item template surfaces the per-option description so users
                                 understand the trade-off before they commit. -->
                            <TextBlock Text="DirectX version (-dxlevel)" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,2"/>
                            <!-- The combo's ItemTemplate already renders Label + Description
                                 for both the dropdown items and the selected box, so we
                                 don't duplicate the description below — single source of truth. -->
                            <ComboBox ItemsSource="{Binding DxLevelOptions}"
                                      SelectedItem="{Binding DxLevelSelected, Mode=TwoWay}"
                                      Width="380" HorizontalAlignment="Left" Margin="0,0,0,12">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="2,4">
                                            <TextBlock Text="{Binding Label}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Description}" Foreground="{DynamicResource SecondaryTextBrush}"
                                                       FontSize="11" TextWrapping="Wrap" MaxWidth="360" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <CheckBox IsChecked="{Binding CurrentSettings.SkipIntro}" Content="Skip intro video (-novid)" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,4"/>
                            <CheckBox IsChecked="{Binding CurrentSettings.DisableJoystick}" Content="Disable joystick (-nojoy)" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,4"/>
                            <CheckBox IsChecked="{Binding CurrentSettings.HighPriority}" Content="High CPU priority (-high)" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,4"/>
                            <CheckBox IsChecked="{Binding CurrentSettings.NoTextureStream}" Content="Disable texture streaming (-no_texture_stream)" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,4"/>
                            <CheckBox IsChecked="{Binding CurrentSettings.DisableReplay}" Content="Disable replay system (-noreplay)" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,4"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ─── Schema-driven categories (Gameplay, Competitive, Performance, ...) ─── -->
                <ItemsControl ItemsSource="{Binding SchemaCategories}"/>

                <!-- ─── Launcher (fixed) ─── -->
                <StackPanel core:ScrollAnchor.Name="launcher" core:ScrollAnchor.Host="{Binding ElementName=ContentScroller}" Margin="0,0,0,30">
                    <TextBlock Text="Launcher" Style="{StaticResource SectionHeaderStyle}" FontSize="20"/>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Behavior" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <CheckBox IsChecked="{Binding MinimizeToTrayOnLaunch}" Content="Minimize to tray on launch" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,4"/>
                            <CheckBox IsChecked="{Binding CloseToTray}" Content="Close to tray" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,4"/>
                            <CheckBox IsChecked="{Binding ShowNotifications}" Content="Show notifications" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,4"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Logging" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <CheckBox IsChecked="{Binding EnableDebugLog}" Content="Enable debug log" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,4"/>
                            <CheckBox IsChecked="{Binding AutoClearLogs}" Content="Auto-clear logs on startup" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Log level" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox ItemsSource="{Binding LogLevels}" SelectedItem="{Binding CurrentLogLevel}" Width="100"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ─── Personalization (fixed: theme picker) ─── -->
                <StackPanel core:ScrollAnchor.Name="personalization" core:ScrollAnchor.Host="{Binding ElementName=ContentScroller}" Margin="0,0,0,30">
                    <TextBlock Text="Personalization" Style="{StaticResource SectionHeaderStyle}" FontSize="20"/>

                    <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="10" Padding="20,18" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Current theme" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding Theme.CurrentTheme.DisplayName}" Foreground="{DynamicResource TextBrush}" FontSize="20" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Theme.CurrentTheme.Description}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,3,12,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="22" VerticalAlignment="Center"
                                    Background="{DynamicResource AccentBrush}">
                                <Border.Effect>
                                    <DropShadowEffect Color="{DynamicResource AccentGlowColor}" BlurRadius="18" ShadowDepth="0" Opacity="0.85"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Theme.AvailableThemes}" Margin="0,4,0,16">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectThemeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Width="170" Height="92" Margin="0,0,12,12"
                                        BorderThickness="0" Background="Transparent"
                                        Cursor="Hand" Focusable="False">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid RenderTransformOrigin="0.5,0.5">
                                                <Grid.RenderTransform>
                                                    <ScaleTransform x:Name="cardScale" ScaleX="1" ScaleY="1"/>
                                                </Grid.RenderTransform>
                                                <Border x:Name="card" CornerRadius="10" BorderThickness="1.5" BorderBrush="{DynamicResource BorderBrush}">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="{Binding PageTop}" Offset="0"/>
                                                            <GradientStop Color="{Binding PageBottom}" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Grid Margin="14,12">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Text="{Binding DisplayName}" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                                                            <Border Width="14" Height="14" CornerRadius="3" Margin="0,0,5,0"><Border.Background><SolidColorBrush Color="{Binding Accent}"/></Border.Background></Border>
                                                            <Border Width="14" Height="14" CornerRadius="3" Margin="0,0,5,0"><Border.Background><SolidColorBrush Color="{Binding Card}"/></Border.Background></Border>
                                                            <Border Width="14" Height="14" CornerRadius="3" Margin="0,0,5,0"><Border.Background><SolidColorBrush Color="{Binding SurfaceAlt}"/></Border.Background></Border>
                                                            <Border Width="14" Height="14" CornerRadius="3"><Border.Background><SolidColorBrush Color="{Binding AccentGlow}"/></Border.Background></Border>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <Border x:Name="activeRing" CornerRadius="10" BorderThickness="2" IsHitTestVisible="False" Visibility="Collapsed" BorderBrush="{DynamicResource AccentBrush}">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="20" ShadowDepth="0" Opacity="0.55"/>
                                                    </Border.Effect>
                                                </Border>
                                                <Border x:Name="activeBadge" Width="20" Height="20" CornerRadius="10" Margin="0,8,8,0" HorizontalAlignment="Right" VerticalAlignment="Top" Visibility="Collapsed" IsHitTestVisible="False" Background="{DynamicResource AccentBrush}">
                                                    <TextBlock Text="&#x2713;" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Value="True">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource EqualsMultiConverter}">
                                                            <Binding Path="Id"/>
                                                            <Binding Path="DataContext.Theme.CurrentTheme.Id" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter TargetName="activeRing" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="activeBadge" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <EventTrigger RoutedEvent="MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="cardScale" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.18"/>
                                                            <DoubleAnimation Storyboard.TargetName="cardScale" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.18"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="cardScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.18"/>
                                                            <DoubleAnimation Storyboard.TargetName="cardScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.18"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- ─── Binds (fixed) ─── -->
                <StackPanel core:ScrollAnchor.Name="binds" core:ScrollAnchor.Host="{Binding ElementName=ContentScroller}" Margin="0,0,0,30">
                    <TextBlock Text="Custom binds" Style="{StaticResource SectionHeaderStyle}" FontSize="20"/>

                    <Button Content="+ Add new bind" Command="{Binding AddBindCommand}" Style="{StaticResource ModernButtonStyle}" HorizontalAlignment="Left" Margin="0,0,0,12"/>

                    <ItemsControl ItemsSource="{Binding CurrentSettings.Binds}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBrush}" CornerRadius="6" Padding="14" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Name" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Background="{DynamicResource SurfaceInsetBrush}" Padding="6,4"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Key" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,0,0,2"/>
                                            <Button Command="{Binding DataContext.StartListeningCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Width="90" Height="28" BorderThickness="0" Cursor="Hand">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                        <Setter Property="Content" Value="{Binding Key}"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="6">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsListening}" Value="True">
                                                                <Setter Property="Background" Value="#FFD700"/>
                                                                <Setter Property="Foreground" Value="Black"/>
                                                                <Setter Property="Content" Value="Press key..."/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="Command" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}" Background="{DynamicResource SurfaceInsetBrush}" Padding="6,4"/>
                                        </StackPanel>
                                        <Button Grid.Column="6" Content="&#x2715;" Command="{Binding DataContext.RemoveBindCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="#7e1f1f" Foreground="White" BorderThickness="0" Width="28" Height="28" VerticalAlignment="Bottom" Cursor="Hand" ToolTip="Remove bind">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Bottom spacer keeps the last section scrollable to the top edge -->
                <Border Height="400"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
