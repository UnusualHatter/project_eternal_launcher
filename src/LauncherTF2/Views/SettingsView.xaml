<UserControl x:Class="LauncherTF2.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DesignWidth="1030">
    <UserControl.Resources>
        <!-- Toggle Switch Style -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent" Cursor="Hand">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Border x:Name="SwitchTrack" Grid.Column="1" Width="40" Height="20" CornerRadius="10" Margin="10,0,0,0">
                                <Border.Background>
                                    <SolidColorBrush x:Name="TrackBrush" Color="#333"/>
                                </Border.Background>
                                <Grid>
                                    <Ellipse x:Name="SwitchKnob" Width="16" Height="16" HorizontalAlignment="Left" Margin="2,0,0,0">
                                        <Ellipse.Fill>
                                            <SolidColorBrush x:Name="KnobBrush" Color="#888"/>
                                        </Ellipse.Fill>
                                        <Ellipse.RenderTransform>
                                            <TranslateTransform x:Name="KnobTransform" X="0"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                </Grid>
                            </Border>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobTransform" 
                                                             Storyboard.TargetProperty="X" 
                                                             To="20" Duration="0:0:0.2" DecelerationRatio="0.5"/>
                                            <ColorAnimation Storyboard.TargetName="TrackBrush" 
                                                            Storyboard.TargetProperty="Color" 
                                                            To="#ff6b00" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="KnobBrush" 
                                                            Storyboard.TargetProperty="Color" 
                                                            To="White" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobTransform" 
                                                             Storyboard.TargetProperty="X" 
                                                             To="0" Duration="0:0:0.2" DecelerationRatio="0.5"/>
                                            <ColorAnimation Storyboard.TargetName="TrackBrush" 
                                                            Storyboard.TargetProperty="Color" 
                                                            To="#333" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="KnobBrush" 
                                                            Storyboard.TargetProperty="Color" 
                                                            To="#888" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Indeterminate"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#ddd"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- Section Header Style -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
        </Style>

        <!-- Label Style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#ccc"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,10,5"/>
        </Style>

        <!-- Input Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Dark ComboBox Style -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="20" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" CornerRadius="0" Background="#222" BorderBrush="#333" BorderThickness="1" />
                <Path x:Name="Arrow" Grid.Column="1" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L0,2 L4,6 L8,2 L8,0 L4,4 z" />
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="ComboBoxTextBox" TargetType="TextBox">
            <Border x:Name="PART_ContentHost" Focusable="False" Background="{TemplateBinding Background}" />
        </ControlTemplate>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#222" />
            <Setter Property="BorderBrush" Value="#333" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton Name="ToggleButton" Template="{StaticResource ComboBoxToggleButton}" Grid.Column="2" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press" />
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="6,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <TextBox x:Name="PART_EditableTextBox" Style="{x:Null}" Template="{StaticResource ComboBoxTextBox}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,3,23,3" Focusable="True" Background="#00000000" Foreground="White" Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}" />
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#222" BorderThickness="1" BorderBrush="#333" />
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Arrays for Dropdowns -->
        <x:Array x:Key="DxLevels" Type="sys:Int32">
            <sys:Int32>81</sys:Int32>
            <sys:Int32>90</sys:Int32>
            <sys:Int32>95</sys:Int32>
        </x:Array>
        
        <x:Array x:Key="AntiAliasingLevels" Type="sys:Int32">
            <sys:Int32>0</sys:Int32>
            <sys:Int32>2</sys:Int32>
            <sys:Int32>4</sys:Int32>
            <sys:Int32>8</sys:Int32>
            <sys:Int32>16</sys:Int32>
        </x:Array>
        
        <x:Array x:Key="AnisoLevels" Type="sys:Int32">
            <sys:Int32>1</sys:Int32>
            <sys:Int32>2</sys:Int32>
            <sys:Int32>4</sys:Int32>
            <sys:Int32>8</sys:Int32>
            <sys:Int32>16</sys:Int32>
        </x:Array>

        <x:Array x:Key="QueueModes" Type="sys:Int32">
            <sys:Int32>-1</sys:Int32>
            <sys:Int32>0</sys:Int32>
            <sys:Int32>1</sys:Int32>
            <sys:Int32>2</sys:Int32>
        </x:Array>

        <x:Array x:Key="SpecModes" Type="sys:Int32">
            <sys:Int32>0</sys:Int32>
            <sys:Int32>1</sys:Int32>
            <sys:Int32>2</sys:Int32>
            <sys:Int32>3</sys:Int32>
            <sys:Int32>4</sys:Int32>
            <sys:Int32>5</sys:Int32>
        </x:Array>

        <!-- Modern Slider Style -->
        <Style x:Key="SliderThumbStyle" TargetType="{x:Type Thumb}">
             <Setter Property="OverridesDefaultStyle" Value="True"/>
             <Setter Property="Template">
                 <Setter.Value>
                     <ControlTemplate TargetType="{x:Type Thumb}">
                         <Grid>
                             <Ellipse x:Name="Ellipse" Fill="White" Stroke="#333" StrokeThickness="1" Width="16" Height="16"/>
                         </Grid>
                         <ControlTemplate.Triggers>
                             <Trigger Property="IsMouseOver" Value="True">
                                 <Setter TargetName="Ellipse" Property="Fill" Value="{StaticResource AccentBrush}"/>
                                 <Setter TargetName="Ellipse" Property="Width" Value="18"/>
                                 <Setter TargetName="Ellipse" Property="Height" Value="18"/>
                             </Trigger>
                             <Trigger Property="IsDragging" Value="True">
                                 <Setter TargetName="Ellipse" Property="Fill" Value="{StaticResource AccentBrush}"/>
                             </Trigger>
                         </ControlTemplate.Triggers>
                     </ControlTemplate>
                 </Setter.Value>
             </Setter>
        </Style>

        <Style TargetType="{x:Type Slider}">
            <Setter Property="Stylus.IsFlicksEnabled" Value="False"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="1" Height="4" Background="#333" CornerRadius="2" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Background="{StaticResource AccentBrush}" Height="4" BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="2" Height="4"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumbStyle}" VerticalAlignment="Center" OverridesDefaultStyle="True"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Settings" FontSize="32" FontWeight="Bold" Foreground="White" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,20,0" Style="{StaticResource ModernScrollViewerStyle}">
            <StackPanel>
                <!-- TF2 Path -->
                <Border Background="{StaticResource CardBrush}" Padding="20" CornerRadius="10" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="TF2 installation path (tf folder)" Foreground="#aaa" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding CurrentSettings.SteamPath, UpdateSourceTrigger=PropertyChanged}" Padding="10" Background="#111"/>
                        
                        <TextBlock Text="Launch Options (Manual)" Foreground="#aaa" Margin="0,15,0,5"/>
                        <TextBox Text="{Binding CurrentSettings.LaunchArgs, UpdateSourceTrigger=PropertyChanged}" Padding="10" Background="#111"/>
                    </StackPanel>
                </Border>

                <!-- LAUNCH OPTIONS HEADER -->
                <TextBlock Text="LAUNCH OPTIONS" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,10,0,10"/>
                <Separator Background="#333" Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Column 1: System & Priority -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="System &amp; Priority" Style="{StaticResource SectionHeaderStyle}"/>
                        
                        <!-- Grid for aligned items -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Skip Intro (-novid)" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding CurrentSettings.SkipIntro}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="1" Text="Disable Joystick (-nojoy)" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding CurrentSettings.DisableJoystick}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="2" Text="High CPU Priority (-high)" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding CurrentSettings.HighPriority}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <!-- Threads + Caution -->
                            <!-- Threads -->
                            <StackPanel Grid.Row="3" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="CPU Cores (-threads)" Style="{StaticResource LabelStyle}"/>
                                <TextBlock Text="Caution!" Foreground="#88FFA500" FontSize="12" Margin="10,0,0,0" VerticalAlignment="Center" ToolTip="Incorrect values can cause instability"/>
                            </StackPanel>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CurrentSettings.Threads}" Width="50" TextAlignment="Center" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="4" Text="DirectX Level" Style="{StaticResource LabelStyle}"/>
                            <ComboBox Grid.Row="4" Grid.Column="1" Width="60" ItemsSource="{StaticResource DxLevels}" SelectedValue="{Binding CurrentSettings.DxLevel}" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>

                    <!-- Column 2: Window & Display -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Window &amp; Display" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Fullscreen" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding CurrentSettings.Fullscreen}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="1" Text="Windowed" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding CurrentSettings.Windowed}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="2" Text="Borderless" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding CurrentSettings.Borderless}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="3" Text="Width" Style="{StaticResource LabelStyle}"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CurrentSettings.Width}" Width="60" TextAlignment="Center" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="4" Text="Height" Style="{StaticResource LabelStyle}"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding CurrentSettings.Height}" Width="60" TextAlignment="Center" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="5" Text="Refresh Rate" Style="{StaticResource LabelStyle}"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding CurrentSettings.RefreshRate}" Width="60" TextAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>

                    <!-- Column 3: Advanced Flags -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Advanced Flags" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="Disable Sound" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding CurrentSettings.DisableSound}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="1" Text="Disable HLTV" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding CurrentSettings.DisableHltv}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="2" Text="Soft Particles Off" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding CurrentSettings.SoftParticlesOff}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="3" Text="Disable Steam Controller" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding CurrentSettings.DisableSteamController}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- AUTOEXEC HEADER -->
                <TextBlock Text="AUTOEXEC (IN-GAME)" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,40,0,10"/>
                <Separator Background="#333" Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Column 1: Graphics & Performance -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Graphics &amp; Performance" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="Auto"/> <!-- Sliders need auto height -->
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="VSync" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding CurrentSettings.VSync}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>
                            
                            <TextBlock Grid.Row="1" Text="Anti-Aliasing" Style="{StaticResource LabelStyle}"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Width="60" ItemsSource="{StaticResource AntiAliasingLevels}" SelectedValue="{Binding CurrentSettings.AntiAliasing}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="2" Text="Anisotropic" Style="{StaticResource LabelStyle}"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Width="60" ItemsSource="{StaticResource AnisoLevels}" SelectedValue="{Binding CurrentSettings.AnisotropicFiltering}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="3" Text="Bloom" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding CurrentSettings.Bloom}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>
                            
                            <!-- Sliders spanning full width -->
                            <StackPanel Grid.Row="4" Margin="0,5,0,5" Grid.ColumnSpan="2">
                                <TextBlock Text="Motion Blur Strength" Style="{StaticResource LabelStyle}"/>
                                <DockPanel>
                                    <TextBlock Text="{Binding ElementName=BlurSlider, Path=Value, StringFormat=N2}" DockPanel.Dock="Right" Width="35" TextAlignment="Right" Foreground="#aaa"/>
                                    <Slider x:Name="BlurSlider" Minimum="0" Maximum="1" Value="{Binding CurrentSettings.MotionBlurStrength}" TickFrequency="0.1"/>
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="5" Margin="0,5,0,5" Grid.ColumnSpan="2">
                                <TextBlock Text="Model LOD" Style="{StaticResource LabelStyle}"/>
                                <DockPanel>
                                    <TextBlock Text="{Binding ElementName=LodSlider, Path=Value}" DockPanel.Dock="Right" Width="35" TextAlignment="Right" Foreground="#aaa"/>
                                    <Slider x:Name="LodSlider" Minimum="-1" Maximum="2" Value="{Binding CurrentSettings.ModelLod}" TickFrequency="1"/>
                                </DockPanel>
                            </StackPanel>

                            <TextBlock Grid.Row="7" Text="Ragdolls" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="7" Grid.Column="1" IsChecked="{Binding CurrentSettings.Ragdolls}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="8" Text="Gibs (Alien)" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="8" Grid.Column="1" IsChecked="{Binding CurrentSettings.AlienGibs}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="9" Text="Gibs (Human)" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="9" Grid.Column="1" IsChecked="{Binding CurrentSettings.HumanGibs}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>
                            
                            <StackPanel Grid.Row="10" Margin="0,5,0,5" Grid.ColumnSpan="2">
                                <TextBlock Text="Detail Distance" Style="{StaticResource LabelStyle}"/>
                                <DockPanel>
                                    <TextBlock Text="{Binding ElementName=DetailSlider, Path=Value}" DockPanel.Dock="Right" Width="35" TextAlignment="Right" Foreground="#aaa"/>
                                    <Slider x:Name="DetailSlider" Minimum="0" Maximum="2000" Value="{Binding CurrentSettings.DetailDistance}" TickFrequency="100"/>
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Column 2: Gameplay -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Gameplay" Style="{StaticResource SectionHeaderStyle}"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                             <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,5" Grid.ColumnSpan="2">
                                <TextBlock Text="FOV" Style="{StaticResource LabelStyle}"/>
                                <DockPanel>
                                    <TextBlock Text="{Binding ElementName=FovSlider, Path=Value}" DockPanel.Dock="Right" Width="35" TextAlignment="Right" Foreground="#aaa"/>
                                    <Slider x:Name="FovSlider" Minimum="70" Maximum="90" Value="{Binding CurrentSettings.Fov}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,5,0,5" Grid.ColumnSpan="2">
                                <TextBlock Text="Viewmodel FOV" Style="{StaticResource LabelStyle}"/>
                                <DockPanel>
                                    <TextBlock Text="{Binding ElementName=VmFovSlider, Path=Value}" DockPanel.Dock="Right" Width="35" TextAlignment="Right" Foreground="#aaa"/>
                                    <Slider x:Name="VmFovSlider" Minimum="54" Maximum="110" Value="{Binding CurrentSettings.ViewmodelFov}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                </DockPanel>
                            </StackPanel>

                            <TextBlock Grid.Row="2" Text="Draw Viewmodel" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding CurrentSettings.DrawViewmodel}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="3" Text="Raw Input" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding CurrentSettings.RawInput}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>
                            
                            <StackPanel Grid.Row="4" Margin="0,5,0,5" Grid.ColumnSpan="2">
                                <TextBlock Text="Sensitivity" Style="{StaticResource LabelStyle}"/>
                                <DockPanel>
                                    <TextBlock Text="{Binding ElementName=SensSlider, Path=Value, StringFormat=N1}" DockPanel.Dock="Right" Width="35" TextAlignment="Right" Foreground="#aaa"/>
                                    <Slider x:Name="SensSlider" Minimum="0.1" Maximum="20" Value="{Binding CurrentSettings.MouseSensitivity}" TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                                </DockPanel>
                            </StackPanel>

                            <TextBlock Grid.Row="5" Text="Auto Reload" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="5" Grid.Column="1" IsChecked="{Binding CurrentSettings.AutoReload}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="6" Text="Hit Sound" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="6" Grid.Column="1" IsChecked="{Binding CurrentSettings.HitSound}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="7" Text="Damage Numbers" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="7" Grid.Column="1" IsChecked="{Binding CurrentSettings.DamageNumbers}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>
                            
                            <StackPanel Grid.Row="8" Margin="0,5,0,5" Grid.ColumnSpan="2">
                                <TextBlock Text="Killstreak Glow" Style="{StaticResource LabelStyle}"/>
                                <DockPanel>
                                    <TextBlock Text="{Binding ElementName=GlowSlider, Path=Value, StringFormat=N1}" DockPanel.Dock="Right" Width="35" TextAlignment="Right" Foreground="#aaa"/>
                                    <Slider x:Name="GlowSlider" Minimum="0" Maximum="10" Value="{Binding CurrentSettings.KillstreakGlow}" TickFrequency="0.5" IsSnapToTickEnabled="True"/>
                                </DockPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Column 3: Interface & Pro -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Interface" Style="{StaticResource SectionHeaderStyle}"/>
                        
                        <Grid>
                             <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                             <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="Auto"/> <!-- Pro/Comp Header -->
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Net Graph" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding CurrentSettings.NetGraph}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>
                            
                            <StackPanel Grid.Row="1" Margin="0,5,0,5" Grid.ColumnSpan="2">
                                <TextBlock Text="Chat Time" Style="{StaticResource LabelStyle}"/>
                                <DockPanel>
                                    <TextBlock Text="{Binding ElementName=ChatSlider, Path=Value}" DockPanel.Dock="Right" Width="35" TextAlignment="Right" Foreground="#aaa"/>
                                    <Slider x:Name="ChatSlider" Minimum="0" Maximum="20" Value="{Binding CurrentSettings.ChatMessageTime}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                </DockPanel>
                            </StackPanel>

                            <TextBlock Grid.Row="2" Text="Draw HUD" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding CurrentSettings.DrawHud}" Style="{StaticResource ToggleSwitchStyle}" ToolTip="Sv_Pure Limited (May not work on Valve servers)" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="3" Text="Pro / Competitive" Style="{StaticResource SectionHeaderStyle}" Margin="0,20,0,10" Grid.ColumnSpan="2"/>
                            
                            <TextBlock Grid.Row="4" Text="Interp" Style="{StaticResource LabelStyle}"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding CurrentSettings.Interp, StringFormat=N6}" Width="80" TextAlignment="Center" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="5" Text="Interpolate" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="5" Grid.Column="1" IsChecked="{Binding CurrentSettings.Interpolate}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="6" Text="Rate" Style="{StaticResource LabelStyle}"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding CurrentSettings.Rate}" Width="80" TextAlignment="Center" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="7" Text="CmdRate" Style="{StaticResource LabelStyle}"/>
                            <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding CurrentSettings.CmdRate}" Width="60" TextAlignment="Center" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="8" Text="UpdateRate" Style="{StaticResource LabelStyle}"/>
                            <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding CurrentSettings.UpdateRate}" Width="60" TextAlignment="Center" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="9" Text="Queue Mode" Style="{StaticResource LabelStyle}"/>
                            <ComboBox Grid.Row="9" Grid.Column="1" Width="60" ItemsSource="{StaticResource QueueModes}" SelectedValue="{Binding CurrentSettings.QueueMode}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="10" Text="Disable Eyes" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="10" Grid.Column="1" IsChecked="{Binding CurrentSettings.DisableEyes}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="11" Text="Disable Flex" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="11" Grid.Column="1" IsChecked="{Binding CurrentSettings.DisableFlex}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- EXTRAS (Advanced) -->
                <Expander Header="EXTRAS" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,20,0,10" IsExpanded="False">
                   <Grid Margin="0,10,0,0" TextElement.FontWeight="Normal">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Column 1 -->
                        <StackPanel Grid.Column="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Text="Show Backpack Rarities" Style="{StaticResource LabelStyle}"/>
                                <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding CurrentSettings.ShowBackpackRarities}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="1" Text="Show In-Game Notifications" Style="{StaticResource LabelStyle}"/>
                                <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding CurrentSettings.ShowIngameNotifications}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="2" Text="Show Plugin Messages" Style="{StaticResource LabelStyle}"/>
                                <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding CurrentSettings.ShowPluginMessages}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <!-- Column 2 -->
                        <StackPanel Grid.Column="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Text="Show Help" Style="{StaticResource LabelStyle}"/>
                                <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding CurrentSettings.ShowHelp}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="1" Text="Ping as Text" Style="{StaticResource LabelStyle}"/>
                                <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding CurrentSettings.ScoreboardPingText}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="2" Text="Spec Mode" Style="{StaticResource LabelStyle}"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" Width="60" ItemsSource="{StaticResource SpecModes}" SelectedValue="{Binding CurrentSettings.SpectatorMode}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <!-- Column 3 -->
                        <StackPanel Grid.Column="4">
                             <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Text="New Impact Effects" Style="{StaticResource LabelStyle}"/>
                                <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding CurrentSettings.NewImpactEffects}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="1" Text="Draw Tracers (1st Person)" Style="{StaticResource LabelStyle}"/>
                                <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding CurrentSettings.DrawTracersFirstPerson}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="2" Text="Colorblind Assist" Style="{StaticResource LabelStyle}"/>
                                <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding CurrentSettings.ColorblindAssist}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                   </Grid>
                </Expander>

                <!-- LAUNCHER CONFIGURATION HEADER -->
                <TextBlock Text="LAUNCHER CONFIGURATION" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,40,0,10"/>
                <Separator Background="#333" Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Column 1: Logging -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Logging" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Enable Debug Log" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding EnableDebugLog}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="1" Text="Log Level" Style="{StaticResource LabelStyle}"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Width="100" ItemsSource="{Binding LogLevels}" SelectedItem="{Binding CurrentLogLevel}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="2" Text="Auto-clear Logs on Startup" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding AutoClearLogs}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>

                    <!-- Column 2: Behavior -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Behavior" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Minimize to Tray on Launch" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding MinimizeToTrayOnLaunch}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="1" Text="Close to Tray Instead of Exit" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding CloseToTray}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>

                            <TextBlock Grid.Row="2" Text="Show Notifications" Style="{StaticResource LabelStyle}"/>
                            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding ShowNotifications}" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- BINDS HEADER -->
                <TextBlock Text="CUSTOM BINDS" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,40,0,10"/>
                <Separator Background="#333" Margin="0,0,0,20"/>
                
                <StackPanel Margin="0,0,0,20">
                    <Button Content="+ Add New Bind" Command="{Binding AddBindCommand}" Style="{StaticResource ModernButtonStyle}" HorizontalAlignment="Right" Margin="0,0,0,15"/>
                    
                    <ItemsControl ItemsSource="{Binding CurrentSettings.Binds}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource CardBrush}" CornerRadius="5" Padding="15" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Bind Name -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Name" Foreground="#777" FontSize="12" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Background="#111" Padding="5"/>
                                        </StackPanel>

                                        <!-- Key Selection Button -->
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Key" Foreground="#777" FontSize="12" Margin="0,0,0,2"/>
                                            <Button Command="{Binding DataContext.StartListeningCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}"
                                                    Width="100" Height="28" BorderThickness="0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="#222"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="Content" Value="{Binding Key}"/>
                                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="3" Padding="5" RenderTransformOrigin="0.5,0.5">
                                                                        <Border.RenderTransform>
                                                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                                        </Border.RenderTransform>
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <EventTrigger RoutedEvent="MouseEnter">
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.1"/>
                                                                                    <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.1"/>
                                                                                    <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="Opacity" To="0.8" Duration="0:0:0.1"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </EventTrigger>
                                                                        <EventTrigger RoutedEvent="MouseLeave">
                                                                            <BeginStoryboard>
                                                                                <Storyboard>
                                                                                    <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1"/>
                                                                                    <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1"/>
                                                                                    <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="Opacity" To="1.0" Duration="0:0:0.1"/>
                                                                                </Storyboard>
                                                                            </BeginStoryboard>
                                                                        </EventTrigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsListening}" Value="True">
                                                                <Setter Property="Background" Value="#FFD700"/>
                                                                <Setter Property="Foreground" Value="Black"/>
                                                                <Setter Property="Content" Value="Press Key..."/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                        
                                        <!-- Command -->
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="Command (Source Engine)" Foreground="#777" FontSize="12" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}" Background="#111" Padding="5"/>
                                        </StackPanel>
                                        
                                        <!-- Remove Button -->
                                        <Button Grid.Column="6" Content="X" 
                                                Command="{Binding DataContext.RemoveBindCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}"
                                                Background="#d32f2f" Foreground="White" BorderThickness="0" 
                                                Width="30" Height="30" VerticalAlignment="Bottom"
                                                ToolTip="Remove Bind">
                                            <Button.Template>
                                                 <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="3" RenderTransformOrigin="0.5,0.5">
                                                        <Border.RenderTransform>
                                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                        </Border.RenderTransform>
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <EventTrigger RoutedEvent="MouseEnter">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.1" Duration="0:0:0.1"/>
                                                                    <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.1" Duration="0:0:0.1"/>
                                                                    <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="Opacity" To="0.8" Duration="0:0:0.1"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                        <EventTrigger RoutedEvent="MouseLeave">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.1"/>
                                                                    <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.1"/>
                                                                    <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="Opacity" To="1.0" Duration="0:0:0.1"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>


                <Button Content="Reset Configuration" Command="{Binding ResetCommand}" 
                        Style="{StaticResource ModernButtonStyle}" Background="#d32f2f" HorizontalAlignment="Right" Margin="0,40,0,20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
