<UserControl x:Class="LauncherTF2.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1030">

    <UserControl.Resources>
        <!-- Toggle switch -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent" Cursor="Hand">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Border x:Name="SwitchTrack" Grid.Column="1" Width="40" Height="20" CornerRadius="10" Margin="10,0,0,0">
                                <Border.Background><SolidColorBrush x:Name="TrackBrush" Color="#333"/></Border.Background>
                                <Grid>
                                    <Ellipse x:Name="SwitchKnob" Width="16" Height="16" HorizontalAlignment="Left" Margin="2,0,0,0">
                                        <Ellipse.Fill><SolidColorBrush x:Name="KnobBrush" Color="#888"/></Ellipse.Fill>
                                        <Ellipse.RenderTransform><TranslateTransform x:Name="KnobTransform" X="0"/></Ellipse.RenderTransform>
                                    </Ellipse>
                                </Grid>
                            </Border>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobTransform" Storyboard.TargetProperty="X" To="20" Duration="0:0:0.18" DecelerationRatio="0.5"/>
                                            <ColorAnimation Storyboard.TargetName="TrackBrush" Storyboard.TargetProperty="Color" To="#ff6b00" Duration="0:0:0.18"/>
                                            <ColorAnimation Storyboard.TargetName="KnobBrush" Storyboard.TargetProperty="Color" To="White" Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KnobTransform" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.18" DecelerationRatio="0.5"/>
                                            <ColorAnimation Storyboard.TargetName="TrackBrush" Storyboard.TargetProperty="Color" To="#333" Duration="0:0:0.18"/>
                                            <ColorAnimation Storyboard.TargetName="KnobBrush" Storyboard.TargetProperty="Color" To="#888" Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Indeterminate"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#ddd"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="CategoryButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1affffff"/>
                                <Setter Property="Foreground" Value="#ccc"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#22ff6b00"/>
                                <Setter Property="Foreground" Value="#ff6b00"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="DescStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,-2,0,6"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1a1a1a"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border Grid.ColumnSpan="2" CornerRadius="4" Background="#1a1a1a" BorderBrush="#333" BorderThickness="1"/>
                <Path Grid.Column="1" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L0,2 L4,6 L8,2 L8,0 L4,4 z"/>
            </Grid>
        </ControlTemplate>
        <ControlTemplate x:Key="ComboBoxTextBox" TargetType="TextBox">
            <Border x:Name="PART_ContentHost" Focusable="False" Background="{TemplateBinding Background}"/>
        </ControlTemplate>
        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1a1a1a"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton Template="{StaticResource ComboBoxToggleButton}" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press"/>
                            <ContentPresenter IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" Margin="8,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <TextBox x:Name="PART_EditableTextBox" Style="{x:Null}" Template="{StaticResource ComboBoxTextBox}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,3,23,3" Focusable="True" Background="#00000000" Foreground="White" Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#222" BorderThickness="1" BorderBrush="#333" CornerRadius="4"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SliderThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Ellipse x:Name="E" Fill="White" Stroke="#333" StrokeThickness="1" Width="16" Height="16"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="E" Property="Fill" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="{x:Type Slider}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="1" Height="4" Background="#333" CornerRadius="2" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Background="{StaticResource AccentBrush}" Height="4" BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="{x:Type RepeatButton}">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="2" Height="4"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumbStyle}" VerticalAlignment="Center"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <x:Array x:Key="DxLevels" Type="sys:Int32">
            <sys:Int32>81</sys:Int32><sys:Int32>90</sys:Int32><sys:Int32>95</sys:Int32>
        </x:Array>
        <x:Array x:Key="AntiAliasingLevels" Type="sys:Int32">
            <sys:Int32>0</sys:Int32><sys:Int32>2</sys:Int32><sys:Int32>4</sys:Int32><sys:Int32>8</sys:Int32><sys:Int32>16</sys:Int32>
        </x:Array>
        <x:Array x:Key="AnisoLevels" Type="sys:Int32">
            <sys:Int32>1</sys:Int32><sys:Int32>2</sys:Int32><sys:Int32>4</sys:Int32><sys:Int32>8</sys:Int32><sys:Int32>16</sys:Int32>
        </x:Array>
        <x:Array x:Key="QueueModes" Type="sys:Int32">
            <sys:Int32>2</sys:Int32><sys:Int32>1</sys:Int32><sys:Int32>0</sys:Int32><sys:Int32>-1</sys:Int32>
        </x:Array>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Background="#0d0d0f" Padding="12,20">
            <StackPanel>
                <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" Foreground="White" Margin="4,0,0,20"/>
                <RadioButton Content="General" IsChecked="True" GroupName="SettingsNav" Style="{StaticResource CategoryButtonStyle}" Click="Category_Click" Tag="GeneralSection"/>
                <RadioButton Content="Game" GroupName="SettingsNav" Style="{StaticResource CategoryButtonStyle}" Click="Category_Click" Tag="GameSection"/>
                <RadioButton Content="Graphics" GroupName="SettingsNav" Style="{StaticResource CategoryButtonStyle}" Click="Category_Click" Tag="GraphicsSection"/>
                <RadioButton Content="Network" GroupName="SettingsNav" Style="{StaticResource CategoryButtonStyle}" Click="Category_Click" Tag="NetworkSection"/>
                <RadioButton Content="Performance" GroupName="SettingsNav" Style="{StaticResource CategoryButtonStyle}" Click="Category_Click" Tag="PerformanceSection"/>
                <RadioButton Content="Launcher" GroupName="SettingsNav" Style="{StaticResource CategoryButtonStyle}" Click="Category_Click" Tag="LauncherSection"/>
                <RadioButton Content="Binds" GroupName="SettingsNav" Style="{StaticResource CategoryButtonStyle}" Click="Category_Click" Tag="BindsSection"/>

                <Button Content="Reset all" Command="{Binding ResetCommand}" Style="{StaticResource ModernButtonStyle}" Background="#7e1f1f" Margin="0,30,0,0" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer x:Name="ContentScroller" Grid.Column="1" VerticalScrollBarVisibility="Auto" Style="{StaticResource ModernScrollViewerStyle}" Padding="30,20,30,20">
            <StackPanel>

                <!-- ═══ GENERAL ═══ -->
                <StackPanel x:Name="GeneralSection" Margin="0,0,0,30">
                    <TextBlock Text="General" Style="{StaticResource SectionHeaderStyle}" FontSize="20"/>

                    <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="TF2 Installation Path" Foreground="#ccc" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Path to your tf folder (e.g. .../Team Fortress 2/tf)" Style="{StaticResource DescStyle}"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Browse" Command="{Binding BrowseFolderCommand}" Style="{StaticResource ModernButtonStyle}" Padding="14,8" Margin="8,0,0,0"/>
                                <TextBox Text="{Binding CurrentSettings.SteamPath, UpdateSourceTrigger=PropertyChanged}"/>
                            </DockPanel>
                            <TextBlock Text="{Binding PathValidationMessage}" FontSize="11" Margin="0,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#ef5350"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPathValid}" Value="True">
                                                <Setter Property="Foreground" Value="#66bb6a"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Display" Foreground="#ccc" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding DisplayModes}" SelectedItem="{Binding DisplayMode}" Width="220" HorizontalAlignment="Left" Margin="0,0,0,12"/>

                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Width" Foreground="#aaa" FontSize="12" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding CurrentSettings.Width}" TextAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Height" Foreground="#aaa" FontSize="12" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding CurrentSettings.Height}" TextAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="Refresh rate (Hz)" Foreground="#aaa" FontSize="12" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding CurrentSettings.RefreshRate}" TextAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Steam launch options" Foreground="#ccc" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Auto-synced from the toggles below. You can also append custom flags here — the launcher won't touch them." Style="{StaticResource DescStyle}"/>
                            <TextBox Text="{Binding CurrentSettings.LaunchArgs, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Launch behavior" Foreground="#ccc" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <CheckBox IsChecked="{Binding CurrentSettings.SkipIntro}" Content="Skip intro video" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,2"/>
                            <TextBlock Text="-novid: skips the Valve logo when TF2 starts" Style="{StaticResource DescStyle}"/>
                            <CheckBox IsChecked="{Binding CurrentSettings.DisableJoystick}" Content="Disable joystick" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,2"/>
                            <TextBlock Text="-nojoy: frees up memory if you don't use a controller" Style="{StaticResource DescStyle}"/>
                            <CheckBox IsChecked="{Binding CurrentSettings.NoTextureStream}" Content="Disable texture streaming" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,2"/>
                            <TextBlock Text="-no_texture_stream: pre-loads all textures (better visuals on fast storage)" Style="{StaticResource DescStyle}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═══ GAME ═══ -->
                <StackPanel x:Name="GameSection" Margin="0,0,0,30">
                    <TextBlock Text="Game" Style="{StaticResource SectionHeaderStyle}" FontSize="20"/>

                    <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Field of view" Foreground="#ccc" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Text="Game FOV" Foreground="#aaa" FontSize="12"/>
                            <DockPanel Margin="0,2,0,8">
                                <TextBlock Text="{Binding ElementName=FovSlider, Path=Value}" DockPanel.Dock="Right" Width="30" TextAlignment="Right" Foreground="#aaa"/>
                                <Slider x:Name="FovSlider" Minimum="70" Maximum="90" Value="{Binding CurrentSettings.Fov}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                            </DockPanel>
                            <TextBlock Text="Viewmodel FOV" Foreground="#aaa" FontSize="12"/>
                            <DockPanel Margin="0,2,0,4">
                                <TextBlock Text="{Binding ElementName=VmFovSlider, Path=Value}" DockPanel.Dock="Right" Width="30" TextAlignment="Right" Foreground="#aaa"/>
                                <Slider x:Name="VmFovSlider" Minimum="54" Maximum="90" Value="{Binding CurrentSettings.ViewmodelFov}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                            </DockPanel>
                            <CheckBox IsChecked="{Binding CurrentSettings.DrawViewmodel}" Content="Draw viewmodel" Style="{StaticResource ToggleSwitchStyle}" Margin="0,4,0,2"/>
                            <TextBlock Text="r_drawviewmodel: shows your weapon model on screen" Style="{StaticResource DescStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Input" Foreground="#ccc" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <CheckBox IsChecked="{Binding CurrentSettings.RawInput}" Content="Raw input" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,2"/>
                            <TextBlock Text="m_rawinput: bypasses OS mouse acceleration for precise aiming" Style="{StaticResource DescStyle}"/>
                            <TextBlock Text="Mouse sensitivity" Foreground="#aaa" FontSize="12"/>
                            <DockPanel Margin="0,2,0,4">
                                <TextBlock Text="{Binding ElementName=SensSlider, Path=Value, StringFormat=N1}" DockPanel.Dock="Right" Width="34" TextAlignment="Right" Foreground="#aaa"/>
                                <Slider x:Name="SensSlider" Minimum="0.1" Maximum="20" Value="{Binding CurrentSettings.MouseSensitivity}" TickFrequency="0.1" IsSnapToTickEnabled="True"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Gameplay" Foreground="#ccc" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <CheckBox IsChecked="{Binding CurrentSettings.AutoReload}" Content="Auto reload" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,2"/>
                            <TextBlock Text="cl_autoreload: reload weapons automatically when not firing" Style="{StaticResource DescStyle}"/>
                            <CheckBox IsChecked="{Binding CurrentSettings.HitSound}" Content="Hit sound" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,2"/>
                            <TextBlock Text="tf_dingalingaling: play a sound when you deal damage" Style="{StaticResource DescStyle}"/>
                            <CheckBox IsChecked="{Binding CurrentSettings.DamageNumbers}" Content="Damage numbers" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,2"/>
                            <TextBlock Text="hud_combattext: show floating damage numbers on hit" Style="{StaticResource DescStyle}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═══ GRAPHICS ═══ -->
                <StackPanel x:Name="GraphicsSection" Margin="0,0,0,30">
                    <TextBlock Text="Graphics" Style="{StaticResource SectionHeaderStyle}" FontSize="20"/>

                    <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Rendering" Foreground="#ccc" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <CheckBox IsChecked="{Binding CurrentSettings.VSync}" Content="VSync" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,2"/>
                            <TextBlock Text="mat_vsync: prevents screen tearing — adds slight input lag" Style="{StaticResource DescStyle}"/>

                            <Grid Margin="0,4,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Anti-aliasing" Foreground="#aaa" FontSize="12" Margin="0,0,0,2"/>
                                    <ComboBox ItemsSource="{StaticResource AntiAliasingLevels}" SelectedValue="{Binding CurrentSettings.AntiAliasing}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Anisotropic" Foreground="#aaa" FontSize="12" Margin="0,0,0,2"/>
                                    <ComboBox ItemsSource="{StaticResource AnisoLevels}" SelectedValue="{Binding CurrentSettings.AnisotropicFiltering}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4">
                                    <TextBlock Text="DirectX level" Foreground="#aaa" FontSize="12" Margin="0,0,0,2"/>
                                    <ComboBox ItemsSource="{StaticResource DxLevels}" SelectedValue="{Binding CurrentSettings.DxLevel}"/>
                                </StackPanel>
                            </Grid>

                            <CheckBox IsChecked="{Binding CurrentSettings.Bloom}" Content="Bloom" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,2"/>
                            <TextBlock Text="Glow effect around bright areas" Style="{StaticResource DescStyle}"/>

                            <TextBlock Text="Motion blur" Foreground="#aaa" FontSize="12"/>
                            <DockPanel Margin="0,2,0,4">
                                <TextBlock Text="{Binding ElementName=BlurSlider, Path=Value, StringFormat=N2}" DockPanel.Dock="Right" Width="38" TextAlignment="Right" Foreground="#aaa"/>
                                <Slider x:Name="BlurSlider" Minimum="0" Maximum="1" Value="{Binding CurrentSettings.MotionBlurStrength}" TickFrequency="0.1"/>
                            </DockPanel>

                            <TextBlock Text="Model LOD" Foreground="#aaa" FontSize="12"/>
                            <DockPanel Margin="0,2,0,4">
                                <TextBlock Text="{Binding ElementName=LodSlider, Path=Value}" DockPanel.Dock="Right" Width="38" TextAlignment="Right" Foreground="#aaa"/>
                                <Slider x:Name="LodSlider" Minimum="-1" Maximum="2" Value="{Binding CurrentSettings.ModelLod}" TickFrequency="1"/>
                            </DockPanel>

                            <TextBlock Text="Detail distance" Foreground="#aaa" FontSize="12"/>
                            <DockPanel Margin="0,2,0,0">
                                <TextBlock Text="{Binding ElementName=DetailSlider, Path=Value}" DockPanel.Dock="Right" Width="42" TextAlignment="Right" Foreground="#aaa"/>
                                <Slider x:Name="DetailSlider" Minimum="0" Maximum="2000" Value="{Binding CurrentSettings.DetailDistance}" TickFrequency="100"/>
                            </DockPanel>

                            <CheckBox IsChecked="{Binding CurrentSettings.Ragdolls}" Content="Ragdolls" Style="{StaticResource ToggleSwitchStyle}" Margin="0,8,0,2"/>
                            <TextBlock Text="cl_ragdoll_physics_enable: physics-based death animations" Style="{StaticResource DescStyle}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═══ NETWORK ═══ -->
                <StackPanel x:Name="NetworkSection" Margin="0,0,0,30">
                    <TextBlock Text="Network" Style="{StaticResource SectionHeaderStyle}" FontSize="20"/>
                    <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Network rates" Foreground="#ccc" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Fine-tune network interpolation. The defaults are reasonable for most players." Style="{StaticResource DescStyle}"/>
                            <Grid Margin="0,4,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"><TextBlock Text="cl_interp" Foreground="#aaa" FontSize="12" Margin="0,0,0,2"/><TextBox Text="{Binding CurrentSettings.Interp, StringFormat=N6}" TextAlignment="Center"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="rate" Foreground="#aaa" FontSize="12" Margin="0,0,0,2"/><TextBox Text="{Binding CurrentSettings.Rate}" TextAlignment="Center"/></StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"><TextBlock Text="cmdrate" Foreground="#aaa" FontSize="12" Margin="0,0,0,2"/><TextBox Text="{Binding CurrentSettings.CmdRate}" TextAlignment="Center"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="updaterate" Foreground="#aaa" FontSize="12" Margin="0,0,0,2"/><TextBox Text="{Binding CurrentSettings.UpdateRate}" TextAlignment="Center"/></StackPanel>
                                <StackPanel Grid.Column="4">
                                    <CheckBox IsChecked="{Binding CurrentSettings.Interpolate}" Content="Interpolate" Style="{StaticResource ToggleSwitchStyle}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>

                            <Border Background="#13131A" BorderBrush="#22222E" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,4,0,0">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <TextBlock Text="Multi-core rendering" Foreground="#ccc" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                                        <ComboBox DockPanel.Dock="Right" ItemsSource="{StaticResource QueueModes}" SelectedValue="{Binding CurrentSettings.QueueMode}" Width="80" HorizontalAlignment="Right"/>
                                    </DockPanel>
                                    <TextBlock Text="mat_queue_mode controls how TF2 spreads rendering work across CPU cores." Foreground="#9999A2" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,2"/>
                                    <TextBlock Foreground="#7B7B85" FontSize="11" TextWrapping="Wrap">
                                        <Run Text="2"/>
                                        <Run Text="— multi-threaded (recommended for modern multi-core CPUs)" Foreground="#888892"/>
                                        <LineBreak/>
                                        <Run Text="1"/>
                                        <Run Text="— two-threaded fallback" Foreground="#888892"/>
                                        <LineBreak/>
                                        <Run Text="0"/>
                                        <Run Text="— single-threaded (only if you hit driver crashes)" Foreground="#888892"/>
                                        <LineBreak/>
                                        <Run Text="-1"/>
                                        <Run Text="— let the engine pick (often falls back to 0)" Foreground="#888892"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═══ PERFORMANCE ═══ -->
                <StackPanel x:Name="PerformanceSection" Margin="0,0,0,30">
                    <TextBlock Text="Performance" Style="{StaticResource SectionHeaderStyle}" FontSize="20"/>

                    <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="FPS tweaks" Foreground="#ccc" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <CheckBox IsChecked="{Binding CurrentSettings.HighPriority}" Content="High CPU priority" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,2"/>
                            <TextBlock Text="-high: runs TF2 with high process priority. May cause instability on some systems." Style="{StaticResource DescStyle}"/>
                            <CheckBox IsChecked="{Binding CurrentSettings.DisableReplay}" Content="Disable replay system" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,2"/>
                            <TextBlock Text="-noreplay: skips loading the replay system, saves memory" Style="{StaticResource DescStyle}"/>
                            <CheckBox IsChecked="{Binding CurrentSettings.SoftParticlesOff}" Content="Disable soft particles" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,2"/>
                            <TextBlock Text="-softparticlesdefaultoff: disables soft-edged particles for extra FPS" Style="{StaticResource DescStyle}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═══ LAUNCHER ═══ -->
                <StackPanel x:Name="LauncherSection" Margin="0,0,0,30">
                    <TextBlock Text="Launcher" Style="{StaticResource SectionHeaderStyle}" FontSize="20"/>

                    <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Behavior" Foreground="#ccc" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <CheckBox IsChecked="{Binding MinimizeToTrayOnLaunch}" Content="Minimize to tray on launch" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,2"/>
                            <TextBlock Text="Hides the launcher to the tray when TF2 starts" Style="{StaticResource DescStyle}"/>
                            <CheckBox IsChecked="{Binding CloseToTray}" Content="Close to tray" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,2"/>
                            <TextBlock Text="The X button hides to tray instead of fully exiting" Style="{StaticResource DescStyle}"/>
                            <CheckBox IsChecked="{Binding ShowNotifications}" Content="Show notifications" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,2"/>
                            <TextBlock Text="Tray balloon notifications for launcher events" Style="{StaticResource DescStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Logging" Foreground="#ccc" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <CheckBox IsChecked="{Binding EnableDebugLog}" Content="Enable debug log" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,2"/>
                            <TextBlock Text="Detailed logging to app_debug.log" Style="{StaticResource DescStyle}"/>
                            <CheckBox IsChecked="{Binding AutoClearLogs}" Content="Auto-clear logs on startup" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,2"/>
                            <TextBlock Text="Wipes the log archive each time the launcher starts" Style="{StaticResource DescStyle}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Log level" Foreground="#aaa" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox ItemsSource="{Binding LogLevels}" SelectedItem="{Binding CurrentLogLevel}" Width="100"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═══ BINDS ═══ -->
                <StackPanel x:Name="BindsSection" Margin="0,0,0,30">
                    <TextBlock Text="Custom binds" Style="{StaticResource SectionHeaderStyle}" FontSize="20"/>

                    <Button Content="+ Add new bind" Command="{Binding AddBindCommand}" Style="{StaticResource ModernButtonStyle}" HorizontalAlignment="Left" Margin="0,0,0,12"/>

                    <ItemsControl ItemsSource="{Binding CurrentSettings.Binds}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource CardBrush}" CornerRadius="6" Padding="14" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Name" Foreground="#666" FontSize="11" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Background="#111" Padding="6,4"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Key" Foreground="#666" FontSize="11" Margin="0,0,0,2"/>
                                            <Button Command="{Binding DataContext.StartListeningCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Width="90" Height="28" BorderThickness="0" Cursor="Hand">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="#222"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="Content" Value="{Binding Key}"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="6">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsListening}" Value="True">
                                                                <Setter Property="Background" Value="#FFD700"/>
                                                                <Setter Property="Foreground" Value="Black"/>
                                                                <Setter Property="Content" Value="Press key..."/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="Command" Foreground="#666" FontSize="11" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}" Background="#111" Padding="6,4"/>
                                        </StackPanel>
                                        <Button Grid.Column="6" Content="✕" Command="{Binding DataContext.RemoveBindCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="#7e1f1f" Foreground="White" BorderThickness="0" Width="28" Height="28" VerticalAlignment="Bottom" Cursor="Hand" ToolTip="Remove bind">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
