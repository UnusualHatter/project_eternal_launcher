<UserControl x:Class="LauncherTF2.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1030">

    <UserControl.Resources>

        <!-- Premium card surface used everywhere on Home -->
        <Style x:Key="HomeCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="shell"
                                Background="#161620"
                                BorderBrush="#23232E"
                                BorderThickness="1"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="shell" Property="Background" Value="#1C1C28"/>
                                <Setter TargetName="shell" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="shell" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#000000" Opacity="0.45" BlurRadius="14" ShadowDepth="3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Quick-action tile (compact icon + label inside HomeCardButtonStyle) -->
        <Style x:Key="QuickActionTileStyle" TargetType="Button" BasedOn="{StaticResource HomeCardButtonStyle}"/>

        <!-- Section header text -->
        <Style x:Key="HomeSectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#E8E8EE"/>
        </Style>

        <Style x:Key="HomeSectionSub" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#5A5A66"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <!-- HUGE display title (TEAM FORTRESS 2) -->
        <Style x:Key="HeroTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="44"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="LineHeight" Value="48"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="14" ShadowDepth="2" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Status dot — colour driven by a DataTrigger on a bool -->
        <Style x:Key="StatusDotOk" TargetType="Ellipse">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Fill" Value="#22C55E"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="StatusDotMissing" TargetType="Ellipse">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Fill" Value="#EF4444"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <!-- Layered background — base + radial accent glow for premium feel -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#13131A" Offset="0"/>
                <GradientStop Color="#0E0E14" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Soft accent glow in the upper-left -->
        <Ellipse Width="500" Height="500" HorizontalAlignment="Left" VerticalAlignment="Top"
                 Margin="-180,-200,0,0" IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                    <GradientStop Color="#33FF6B00" Offset="0"/>
                    <GradientStop Color="#00FF6B00" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TranslateTransform Y="10"/>
            </Grid.RenderTransform>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.32"/>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="10" To="0" Duration="0:0:0.32" DecelerationRatio="0.4"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource ModernScrollViewerStyle}" Padding="40,32,40,40">
                <StackPanel>

                    <!-- ───────────────  HERO  ─────────────── -->
                    <Grid Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#7B7B85">
                                    <Run Text="{Binding Greeting, Mode=OneWay}"/>
                                    <Run Text=", "/>
                                    <Run Text="{Binding UserName, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Text="TEAM FORTRESS 2" Style="{StaticResource HeroTitleStyle}"/>
                            <TextBlock Text="{Binding Tagline}" Foreground="#9090A0" FontSize="14" Margin="0,8,0,0"/>

                            <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                                <Button Content="▶  LAUNCH TF2" Command="{Binding PlayCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}" Padding="28,13" FontSize="13"/>
                                <Button Content="Refresh feed" Command="{Binding RefreshCommand}"
                                        Style="{StaticResource GhostButtonStyle}" Margin="10,0,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Status pills column -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="220">
                            <Border Background="#16161B" BorderBrush="#23232E" BorderThickness="1" CornerRadius="12" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="STATUS" Foreground="#5A5A66" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                    <!-- TF2 detected -->
                                    <DockPanel Margin="0,0,0,6">
                                        <Ellipse DockPanel.Dock="Left" Margin="0,0,10,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse" BasedOn="{StaticResource StatusDotMissing}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Tf2Detected}" Value="True">
                                                            <Setter Property="Fill" Value="#22C55E"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="TF2 install" Foreground="#C8C8D2" FontSize="12"/>
                                    </DockPanel>

                                    <!-- Steam detected -->
                                    <DockPanel Margin="0,0,0,6">
                                        <Ellipse DockPanel.Dock="Left" Margin="0,0,10,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse" BasedOn="{StaticResource StatusDotMissing}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SteamDetected}" Value="True">
                                                            <Setter Property="Fill" Value="#22C55E"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="Steam session" Foreground="#C8C8D2" FontSize="12"/>
                                    </DockPanel>

                                    <!-- Autoexec detected -->
                                    <DockPanel Margin="0,0,0,6">
                                        <Ellipse DockPanel.Dock="Left" Margin="0,0,10,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse" BasedOn="{StaticResource StatusDotMissing}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding AutoexecDetected}" Value="True">
                                                            <Setter Property="Fill" Value="#22C55E"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="autoexec.cfg" Foreground="#C8C8D2" FontSize="12"/>
                                    </DockPanel>

                                    <!-- Mods count -->
                                    <DockPanel>
                                        <Ellipse DockPanel.Dock="Left" Margin="0,0,10,0" Width="8" Height="8" Fill="#FF6B00" VerticalAlignment="Center"/>
                                        <TextBlock Foreground="#C8C8D2" FontSize="12">
                                            <Run Text="{Binding ModsCount, Mode=OneWay}"/>
                                            <Run Text=" mods installed"/>
                                        </TextBlock>
                                    </DockPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- ───────────────  QUICK ACTIONS  ─────────────── -->
                    <UniformGrid Columns="4" Margin="0,0,0,40">
                        <Button Style="{StaticResource QuickActionTileStyle}" Command="{Binding OpenTf2FolderCommand}" Margin="0,0,8,0" Height="84">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="📁" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="TF2 folder" Foreground="#D4D4DC" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource QuickActionTileStyle}" Command="{Binding OpenCustomFolderCommand}" Margin="4,0,4,0" Height="84">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🧩" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="Mods folder" Foreground="#D4D4DC" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource QuickActionTileStyle}" Command="{Binding OpenAutoexecCommand}" Margin="4,0,4,0" Height="84">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="⚙" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="Edit autoexec" Foreground="#D4D4DC" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource QuickActionTileStyle}" Command="{Binding BackupConfigCommand}" Margin="8,0,0,0" Height="84">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="💾" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="Backup config" Foreground="#D4D4DC" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </UniformGrid>

                    <!-- ───────────────  TF2 NEWS  ─────────────── -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Latest from TF2 Blog" Style="{StaticResource HomeSectionTitle}"/>
                            <TextBlock Text="Official Steam announcements, updates, and patch notes" Style="{StaticResource HomeSectionSub}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="via Steam" VerticalAlignment="Center" Foreground="#5A5A66" FontSize="11"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding NewsItems}" Margin="0,0,0,32">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource HomeCardButtonStyle}"
                                        Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Url}"
                                        Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="172" Height="108"
                                                CornerRadius="14,0,0,14" Background="#0E0E13"
                                                ClipToBounds="True">
                                            <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="22,18,22,18" VerticalAlignment="Center">
                                            <DockPanel Margin="0,0,0,4">
                                                <TextBlock Text="{Binding DateFormatted}" Foreground="#5A5A66"
                                                           FontSize="10.5" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                                                <Border DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                        Background="#22FF6B00" CornerRadius="999" Padding="9,2">
                                                    <TextBlock Text="{Binding FeedLabel}" Foreground="{StaticResource AccentBrush}"
                                                               FontSize="9.5" FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock/>
                                            </DockPanel>
                                            <TextBlock Text="{Binding Title}" Foreground="White" FontSize="15"
                                                       FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding Contents}" Foreground="#9090A0"
                                                       FontSize="12" TextWrapping="Wrap" MaxHeight="34"
                                                       ClipToBounds="True"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ───────────────  GAMEBANANA MODS  ─────────────── -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Fresh on GameBanana" Style="{StaticResource HomeSectionTitle}"/>
                            <TextBlock Text="The newest community releases (NSFW filtered)" Style="{StaticResource HomeSectionSub}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="scroll →" VerticalAlignment="Center" Foreground="#5A5A66" FontSize="11"/>
                    </Grid>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                  Style="{StaticResource ModernScrollViewerStyle}">
                        <ItemsControl ItemsSource="{Binding NewMods}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource HomeCardButtonStyle}"
                                            Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding ProfileUrl}"
                                            Width="220" Margin="0,0,14,4">
                                        <StackPanel>
                                            <Border Height="124" CornerRadius="14,14,0,0" Background="#0E0E13" ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    <Border Background="#33000000"
                                                            Visibility="{Binding ThumbnailUrl, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}">
                                                        <TextBlock Text="No preview" Foreground="#9696A2"
                                                                   FontWeight="SemiBold" HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <StackPanel Margin="14,12,14,14">
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13"
                                                           FontWeight="SemiBold" TextWrapping="Wrap"
                                                           MaxHeight="36" ClipToBounds="True"/>
                                                <TextBlock Margin="0,6,0,0" FontSize="11">
                                                    <Run Text="by " Foreground="#5A5A66"/>
                                                    <Run Text="{Binding Author}" Foreground="#A6A6B2"/>
                                                </TextBlock>
                                                <TextBlock Text="{Binding DateFormatted}" Foreground="#5A5A66" FontSize="10" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Loading indicator -->
                    <Border Background="#15151B" BorderBrush="#23232C" BorderThickness="1" CornerRadius="10"
                            Padding="14,10" Margin="0,18,0,0" HorizontalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <ProgressBar Width="100" Height="3" IsIndeterminate="True" Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Text="Loading feed..." Foreground="#A6A6B2" Margin="12,0,0,0" FontSize="12"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
