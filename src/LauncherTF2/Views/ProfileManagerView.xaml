<Window x:Class="LauncherTF2.Views.ProfileManagerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="Profile Manager"
        Height="480" Width="760"
        MinHeight="420" MinWidth="680"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PageBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">

    <WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="36"
            CornerRadius="12"
            GlassFrameThickness="0"
            UseAeroCaptionButtons="False"
            ResizeBorderThickness="0"
            NonClientFrameEdges="None"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>

        <!-- Compact list item -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Icon -->
                                <Border Width="30" Height="30" CornerRadius="6"
                                        Background="{DynamicResource SurfaceAltBrush}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="⚙" FontSize="13"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                </Border>
                                <!-- Text -->
                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Description}"
                                               FontSize="10" Margin="0,2,0,0"
                                               Opacity="0.6"
                                               TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding Description, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A4F8CFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- Section label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Margin" Value="2,0,0,6"/>
            <Setter Property="Opacity" Value="0.7"/>
        </Style>

        <!-- Pill badge -->
        <Style x:Key="BadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Destructive (delete) button -->
        <Style x:Key="DestructiveButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#3D1515"/>
            <Setter Property="Foreground" Value="#FF6B6B"/>
        </Style>

    </Window.Resources>

    <Border Background="{DynamicResource PageBackgroundBrush}"
            BorderBrush="#18FFFFFF"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Title bar ── -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SurfaceInsetBrush}"
                    CornerRadius="12,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="⚙" FontSize="13" Margin="0,0,7,0" Foreground="{DynamicResource AccentBrush}"/>
                        <TextBlock Text="Profile Manager" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Width="36" Height="36"
                            Content="✕" FontSize="11"
                            Background="Transparent"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            BorderThickness="0" Cursor="Hand"
                            Click="CloseButton_Click"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- ── Main content ── -->
            <Grid Grid.Row="1" Margin="16,14,16,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── Left: profile list ── -->
                <Border Grid.Column="0"
                        Background="{DynamicResource CardBrush}"
                        CornerRadius="10"
                        Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Style="{StaticResource ModernScrollViewerStyle}">
                        <StackPanel>

                            <!-- User profiles -->
                            <TextBlock Text="USER PROFILES" Style="{StaticResource SectionLabel}"/>
                            <ListBox x:Name="UserProfilesListBox"
                                     ItemsSource="{Binding UserProfiles}"
                                     SelectionMode="Single"
                                     SelectionChanged="UserProfilesListBox_SelectionChanged"
                                     Margin="0,0,0,10"/>

                            <!-- Empty state for user profiles -->
                            <TextBlock Text="No saved profiles yet."
                                       FontSize="11" Margin="4,0,0,10"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Opacity="0.5">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UserProfiles.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Separator -->
                            <Border Height="1" Background="{DynamicResource BorderBrush}"
                                    Margin="0,2,0,10" Opacity="0.4"/>

                            <!-- Built-in presets -->
                            <TextBlock Text="BUILT-IN PRESETS" Style="{StaticResource SectionLabel}"/>
                            <ListBox x:Name="BuiltInProfilesListBox"
                                     ItemsSource="{Binding BuiltInProfiles}"
                                     SelectionMode="Single"
                                     SelectionChanged="BuiltInProfilesListBox_SelectionChanged"/>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ── Right: detail + actions ── -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Detail panel (profile selected) -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource CardBrush}"
                            CornerRadius="10"
                            Padding="20,16">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedProfile}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <DockPanel>
                            <!-- Action buttons — docked to bottom -->
                            <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">

                                <!-- Primary actions: always visible -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button Content="Apply Profile"
                                            Command="{Binding ApplyProfileCommand}"
                                            Style="{StaticResource ModernButtonStyle}"
                                            Background="{DynamicResource AccentBrush}"
                                            Foreground="White"
                                            Padding="16,8" Margin="0,0,8,0"/>
                                    <Button Content="Duplicate"
                                            Command="{Binding DuplicateProfileCommand}"
                                            Style="{StaticResource ModernButtonStyle}"
                                            Padding="16,8" Margin="0,0,8,0"/>
                                </StackPanel>

                                <!-- User-only actions -->
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedProfile.IsUserCreated}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Button Content="Rename"
                                            Command="{Binding RenameProfileCommand}"
                                            Style="{StaticResource ModernButtonStyle}"
                                            Padding="14,6" Margin="0,0,8,0"/>
                                    <Button Content="Export"
                                            Command="{Binding ExportProfileCommand}"
                                            Style="{StaticResource ModernButtonStyle}"
                                            Padding="14,6" Margin="0,0,8,0"/>
                                    <Button Content="Delete"
                                            Command="{Binding DeleteProfileCommand}"
                                            Style="{StaticResource DestructiveButtonStyle}"
                                            Padding="14,6"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Profile info -->
                            <StackPanel>
                                <!-- Name + type badge -->
                                <DockPanel Margin="0,0,0,6">
                                    <!-- Type badge -->
                                    <Border DockPanel.Dock="Right"
                                            VerticalAlignment="Top"
                                            Margin="8,4,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource BadgeStyle}">
                                                <Setter Property="Background" Value="#1A4F8CFF"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedProfile.IsUserCreated}" Value="False">
                                                        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="10" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="User Profile"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedProfile.IsUserCreated}" Value="False">
                                                            <Setter Property="Text" Value="Built-in"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <TextBlock Text="{Binding SelectedProfile.Name}"
                                               FontSize="20" FontWeight="Bold"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>

                                <!-- Description -->
                                <TextBlock Text="{Binding SelectedProfile.Description}"
                                           FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           MaxHeight="52"
                                           Margin="0,0,0,12"/>

                                <!-- Applied indicator -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelectedProfileApplied}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Ellipse Width="7" Height="7" Fill="#66BB6A"
                                             Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Currently applied"
                                               FontSize="12" Foreground="#66BB6A"/>
                                </StackPanel>

                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Empty state (nothing selected) -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource CardBrush}"
                            CornerRadius="10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedProfile}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="⚙" FontSize="32" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Opacity="0.3" Margin="0,0,0,10"/>
                            <TextBlock Text="Select a profile to see details"
                                       FontSize="13"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Opacity="0.5"/>
                        </StackPanel>
                    </Border>

                    <!-- Footer -->
                    <DockPanel Grid.Row="1" Margin="0,10,0,0">
                        <Button DockPanel.Dock="Right"
                                Content="Close"
                                Click="CloseButton_Click"
                                Style="{StaticResource ModernButtonStyle}"
                                Padding="18,8"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="New Profile"
                                    Command="{Binding NewProfileCommand}"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Padding="14,8" Margin="0,0,8,0"/>
                            <Button Content="Save Current Settings"
                                    Command="{Binding SaveCurrentAsProfileCommand}"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Padding="14,8" Margin="0,0,8,0"/>
                            <Button Content="Import Profile"
                                    Command="{Binding ImportProfileCommand}"
                                    Style="{StaticResource ModernButtonStyle}"
                                    Padding="14,8"/>
                        </StackPanel>
                    </DockPanel>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
