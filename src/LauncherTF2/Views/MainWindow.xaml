<Window x:Class="LauncherTF2.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:LauncherTF2.ViewModels"
        xmlns:views="clr-namespace:LauncherTF2.Views"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        mc:Ignorable="d"
        Title="Eternal TF2 Launcher" Height="720" Width="1280"
        MinWidth="1280" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/Resources/Assets/logo64.png">


    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:InventoryViewModel}">
            <views:InventoryView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ModsViewModel}">
            <views:ModsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>

    <Border CornerRadius="12" Background="{StaticResource BackgroundBrush}" BorderBrush="#333" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/> <!-- Top Bar -->
                <RowDefinition Height="*"/>  <!-- Main Content -->
            </Grid.RowDefinitions>
            
            <!-- Custom Top Bar -->
            <Grid Grid.Row="0" Background="#111" MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Eternal TF2" Foreground="#888" VerticalAlignment="Center" Margin="15,0,0,0" FontWeight="SemiBold" IsHitTestVisible="False"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="—" Width="40" Background="Transparent" Foreground="#aaa" BorderThickness="0" Click="MinimizeButton_Click"/>
                    <Button Content="X" Width="40" Background="Transparent" Foreground="#aaa" BorderThickness="0" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- Main Split -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- System Tray Icon -->
        <tb:TaskbarIcon x:Name="TrayIcon" ToolTipText="Eternal TF2 Launcher" DoubleClickCommand="{Binding RestoreWindowCommand}">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Open" Command="{Binding RestoreWindowCommand}"/>
                    <MenuItem Header="Exit" Command="{Binding QuitCommand}"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- Sidebar -->
        <Grid Grid.Column="0">
            <!-- Home Background (Default Visible) -->
            <Border x:Name="HomeBackground" Opacity="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#E60f0f11" Offset="0.0"/>
                        <GradientStop Color="#00000000" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHome}" Value="False">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.4"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.4"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <!-- Normal Background (Default Hidden) -->
            <Border x:Name="NormalBackground" Background="{StaticResource SidebarBrush}" Opacity="0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHome}" Value="False">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.4"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.4"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <StackPanel>
                <!-- Logo Area -->
                <Image Source="/Resources/Assets/logo.png" Height="60" Margin="0,30,0,50" HorizontalAlignment="Center">
                    <Image.Effect>
                        <DropShadowEffect Color="{StaticResource AccentColor}" BlurRadius="10" ShadowDepth="0"/>
                    </Image.Effect>
                </Image>

                <!-- Navigation -->
                <RadioButton Content="Home" Style="{StaticResource SidebarButtonStyle}" Command="{Binding HomeViewCommand}" IsChecked="True"/>
                <RadioButton Content="Inventory" Style="{StaticResource SidebarButtonStyle}" Command="{Binding InventoryViewCommand}"/>
                <RadioButton Content="Mods" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ModsViewCommand}"/>

                <RadioButton Content="Settings" Style="{StaticResource SidebarButtonStyle}" Command="{Binding SettingsViewCommand}"/>
                
                <Separator Background="#333" Margin="20,20"/>
                
                <RadioButton Content="Quit" Style="{StaticResource SidebarButtonStyle}" Command="{Binding QuitCommand}"/>
                
                <!-- Giant Play Button -->
                <Button Content="LAUNCH TF2" 
                        Command="{Binding GlobalPlayCommand}"
                        Style="{StaticResource ModernButtonStyle}" 
                        Background="#2e7d32" 
                        Foreground="White"
                        FontSize="18"
                        FontWeight="Black"
                        Margin="20,40,20,0"
                        Height="60"/>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <ContentControl x:Name="MainContentControl" Grid.Column="1" Content="{Binding CurrentView}" Margin="0" Opacity="1" RenderTransformOrigin="0.5,0.5">
            <ContentControl.RenderTransform>
                <TranslateTransform Y="0"/>
            </ContentControl.RenderTransform>
        </ContentControl>
            </Grid>
        </Grid>
    </Border>
</Window>
