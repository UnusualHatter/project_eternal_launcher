<Window x:Class="LauncherTF2.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm" Height="200" Width="420"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#CC2222"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#E63030"/>
    </Window.Resources>

    <Border Background="#141414" CornerRadius="14"
            BorderBrush="#2A2A2A" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>

        <Grid Margin="28,24,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Icon + Title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                <!-- Warning icon -->
                <Border Width="32" Height="32" CornerRadius="8" Background="#2A0A0A"
                        Margin="0,0,12,0" VerticalAlignment="Center">
                    <Path Fill="#CC2222" Data="M12 2L1 21h22L12 2zm0 3.5L20.5 19h-17L12 5.5zm-1 5v5h2v-5h-2zm0 6v2h2v-2h-2z"
                          Stretch="Uniform" Width="16" Height="16"/>
                </Border>
                <TextBlock x:Name="TitleText" Text="Remove Mod"
                           Foreground="White" FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI"/>
            </StackPanel>

            <!-- Message -->
            <TextBlock Grid.Row="1" x:Name="MessageText"
                       Foreground="#AAAAAA" FontSize="13"
                       TextWrapping="Wrap" LineHeight="20"
                       FontFamily="Segoe UI"
                       VerticalAlignment="Center"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,18,0,0"
                        VerticalAlignment="Bottom">

                <!-- Cancel -->
                <Button x:Name="CancelButton" Content="Cancel"
                        Width="90" Height="34" Margin="0,0,10,0"
                        Cursor="Hand" Click="CancelButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#1E1E1E" CornerRadius="8"
                                    BorderThickness="1" BorderBrush="#333">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#2A2A2A"/>
                                    <Setter TargetName="Bg" Property="BorderBrush" Value="#555"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground>
                        <SolidColorBrush Color="#CCCCCC"/>
                    </Button.Foreground>
                    <Button.FontFamily>
                        <FontFamily>Segoe UI</FontFamily>
                    </Button.FontFamily>
                    <Button.FontSize>13</Button.FontSize>
                </Button>

                <!-- Confirm / Delete -->
                <Button x:Name="ConfirmButton" Content="Remove"
                        Width="90" Height="34"
                        Cursor="Hand" Click="ConfirmButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="#CC2222" CornerRadius="8"
                                    BorderThickness="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#E63030"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#AA1A1A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground>
                        <SolidColorBrush Color="White"/>
                    </Button.Foreground>
                    <Button.FontFamily>
                        <FontFamily>Segoe UI</FontFamily>
                    </Button.FontFamily>
                    <Button.FontSize>13</Button.FontSize>
                    <Button.FontWeight>SemiBold</Button.FontWeight>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
