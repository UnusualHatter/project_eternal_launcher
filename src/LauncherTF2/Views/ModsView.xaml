<UserControl x:Class="LauncherTF2.Views.ModsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:LauncherTF2.ViewModels"
             xmlns:local="clr-namespace:LauncherTF2.Views"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1030">
    <UserControl.Resources>
        <!-- Converter for switching layouts -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <Style x:Key="CategoryBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
        </Style>

        <!-- Toggle Switch Style (Simplified for this view) -->
        <Style x:Key="ModActivationToggleStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Background" Width="40" Height="20" Background="#444" CornerRadius="10">
                            <Ellipse x:Name="Dot" Width="14" Height="14" Fill="White" HorizontalAlignment="Left" Margin="3,0">
                                <Ellipse.RenderTransform>
                                    <TranslateTransform X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Background" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Dot" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="20" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Dot" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Grid Item Template -->
        <DataTemplate x:Key="GridModTemplate">
            <Border Margin="8" Background="{StaticResource CardBrush}" CornerRadius="12" Width="250" Height="350">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="160"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Thumbnail -->
                    <Border Grid.Row="0" CornerRadius="12,12,0,0" Background="#111">
                        <Image Source="{Binding ThumbnailPath}" Stretch="UniformToFill" Opacity="0.9"/>
                    </Border>

                    <Border Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12" Background="#AA111111" CornerRadius="12" Padding="10,5">
                        <TextBlock Text="{Binding SourceLabel}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                    </Border>
                    
                    <!-- Content -->
                    <Border Grid.Row="1" Padding="18,15">
                        <StackPanel>
                            <Button Background="Transparent" BorderThickness="0" Padding="0" HorizontalAlignment="Left"
                                    Cursor="Hand"
                                    Command="{Binding DataContext.OpenModPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                            </Button>
                            <TextBlock Text="{Binding Author}" Foreground="#888" FontSize="12" Margin="0,3,0,6" TextTrimming="CharacterEllipsis"/>

                            <ItemsControl ItemsSource="{Binding Categories}" Margin="0,0,0,10">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CategoryBadgeStyle}">
                                            <TextBlock Text="{Binding}" Foreground="#DADADA" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{Binding Description}" Foreground="#aaa" FontSize="11" TextWrapping="Wrap" MaxHeight="60" TextTrimming="CharacterEllipsis" Margin="0,0,0,12"/>
                            
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Version}" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold"/>
                                    <TextBlock Text=" • " Foreground="#666" VerticalAlignment="Center" FontSize="10"/>
                                    <TextBlock Text="{Binding SourceLabel}" Foreground="#999" VerticalAlignment="Center" FontSize="10"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <CheckBox IsChecked="{Binding IsEnabled}" Style="{StaticResource ModActivationToggleStyle}"
                                              IsEnabled="{Binding IsInstalled}"
                                              Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}"
                                              Command="{Binding DataContext.ToggleModActivationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}"/>
                                    <Button Content="Download"
                                            Padding="12,5"
                                            Background="{StaticResource AccentBrush}"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Margin="8,0,0,0"
                                            Visibility="{Binding IsInstalled, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                            IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBooleanConverter}}"
                                            Command="{Binding DataContext.DownloadOnlineModCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- List Item Template -->
        <DataTemplate x:Key="ListModTemplate">
            <Border Margin="0,0,0,10" Background="{StaticResource CardBrush}" CornerRadius="8" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="76"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Width="60" Height="60" CornerRadius="8" Background="#111">
                         <Image Source="{Binding ThumbnailPath}" Stretch="UniformToFill"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                        <Button Background="Transparent" BorderThickness="0" Padding="0" HorizontalAlignment="Left"
                                Cursor="Hand"
                                Command="{Binding DataContext.OpenModPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">
                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                        </Button>
                        <TextBlock Text="{Binding Author}" Foreground="#888" FontSize="12" TextTrimming="CharacterEllipsis"/>
                        <ItemsControl ItemsSource="{Binding Categories}" Margin="0,6,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CategoryBadgeStyle}">
                                        <TextBlock Text="{Binding}" Foreground="#DADADA" FontSize="10" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <TextBlock Grid.Column="2" Text="{Binding Description}" Foreground="#aaa" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,20,0"/>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,20,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Version}" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SourceLabel}" Foreground="#888" HorizontalAlignment="Right" FontSize="10"/>
                        </StackPanel>
                        <Grid>
                            <CheckBox IsChecked="{Binding IsEnabled}" Style="{StaticResource ModActivationToggleStyle}"
                                      IsEnabled="{Binding IsInstalled}"
                                      Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}"
                                      Command="{Binding DataContext.ToggleModActivationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      CommandParameter="{Binding}"/>
                            <Button Content="Download"
                                    Padding="12,4"
                                    Background="{StaticResource AccentBrush}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Visibility="{Binding IsInstalled, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                    IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBooleanConverter}}"
                                    Command="{Binding DataContext.DownloadOnlineModCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                            <Button Content="Abrir"
                                    Padding="10,4"
                                    Margin="0,32,0,0"
                                    Background="#2F2F2F"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Visibility="{Binding IsInstalled, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                    Command="{Binding DataContext.OpenModPageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="30,10,30,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Library -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search and Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="Mod Library" FontSize="32" FontWeight="Black" Foreground="White" VerticalAlignment="Center" Margin="0,0,40,0"/>
                
                <!-- Search Box -->
                <Border Background="#222" CornerRadius="20" Width="300" Height="40" Padding="15,0">
                    <Grid>
                        <TextBlock Text="Search mods..." Foreground="#555" VerticalAlignment="Center" 
                                   Visibility="{Binding SearchQuery, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}"/>
                        <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="Transparent" BorderThickness="0" Foreground="White" VerticalContentAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- View Toggles Only -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Command="{Binding RefreshCatalogCommand}" 
                        Background="#333" 
                        Foreground="White" 
                        BorderThickness="0" 
                        Cursor="Hand" 
                        Width="36" Height="36" 
                        Margin="0,0,8,0"
                        ToolTip="Refresh Catalog">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="6"
                                                Padding="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#444"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <Path Fill="White" Width="16" Height="16" Stretch="Uniform">
                        <Path.Data>
                            M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z
                        </Path.Data>
                    </Path>
                </Button>

                <Button Command="{Binding ToggleViewModeCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" Width="36" Height="36" ToolTip="Toggle View">
                    <Grid>
                        <Path Fill="#aaa" Width="18" Height="18" Stretch="Uniform" Visibility="{Binding IsGridView, Converter={StaticResource BoolToVis}}">
                            <Path.Data>
                                M3 3h7v7H3V3zm9 0h7v7h-7V3zM3 12h7v7H3v-7zm9 0h7v7h-7v-7z
                            </Path.Data>
                        </Path>
                        <Path Fill="#aaa" Width="18" Height="18" Stretch="Uniform" Visibility="{Binding IsGridView, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <Path.Data>
                                M3 4h18v2H3V4zm0 6h18v2H3v-2zm0 6h18v2H3v-2z
                            </Path.Data>
                        </Path>
                    </Grid>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="6"
                                                Padding="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#333"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Mod Grid/List Container -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <TextBlock Text="{Binding CatalogStatus}" Foreground="#8A8A8A" Margin="0,0,0,10"/>
                <ProgressBar IsIndeterminate="True" 
                             Visibility="{Binding IsLoadingOnlineCatalog, Converter={StaticResource BoolToVis}}"
                             HorizontalAlignment="Left" 
                             VerticalAlignment="Center" 
                             Width="200" 
                             Height="3" 
                             Margin="0,8,0,10"/>
            </Grid>
            <ScrollViewer Grid.Row="1" Style="{StaticResource ModernScrollViewerStyle}" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" ScrollChanged="ModsScrollViewer_OnScrollChanged">
            <Grid>
                <!-- Grid View -->
                <ItemsControl ItemsSource="{Binding DisplayedModsView}" 
                             ItemTemplate="{StaticResource GridModTemplate}"
                             Visibility="{Binding IsGridView, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- List View -->
                <ItemsControl ItemsSource="{Binding DisplayedModsView}" 
                             ItemTemplate="{StaticResource ListModTemplate}"
                             Visibility="{Binding IsGridView, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <Border Background="#161616" CornerRadius="14" Padding="24" Margin="8" Visibility="{Binding DisplayedModsView.IsEmpty, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="No mods match your current filters. Try another section, search term, or refresh the catalog." 
                               Foreground="#999" TextWrapping="Wrap" TextAlignment="Center" FontSize="14"/>
                </Border>
            </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
