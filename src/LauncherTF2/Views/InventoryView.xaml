<UserControl x:Class="LauncherTF2.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:invModels="clr-namespace:LauncherTF2.Models.Inventory"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1030">

    <UserControl.Resources>

        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#15151B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#2C2C36"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ItemCardTemplate" DataType="{x:Type invModels:BackpackGridItem}">
            <Button Style="{StaticResource ItemCardStyle}"
                    Command="{Binding DataContext.SelectItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}"
                    Width="156" Height="200" Margin="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Height="108"
                            BorderBrush="{Binding BorderColorHex}"
                            BorderThickness="0,0,0,2.5"
                            Background="#0E0E13"
                            CornerRadius="6">
                        <Grid>
                            <Image Source="{Binding Image}" Stretch="Uniform" Margin="8"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>

                            <Border Background="#1A1A22" CornerRadius="4" Margin="20"
                                    Visibility="{Binding HasImage, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <TextBlock Text="• • •" Foreground="#3A3A44" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4"
                                    Padding="5,2" Background="#CC6B1B1B" CornerRadius="8"
                                    Visibility="{Binding IsEquipped, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="EQP" FontSize="8" Foreground="#FFB0B0" FontWeight="Bold"/>
                            </Border>

                            <Ellipse HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6"
                                     Width="7" Height="7" Fill="{StaticResource AccentBrush}"
                                     Visibility="{Binding HasAccent, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="4,7,4,4">
                        <TextBlock Text="{Binding Name}" Foreground="White" FontSize="11.5" FontWeight="SemiBold"
                                   TextWrapping="Wrap" MaxHeight="30" ClipToBounds="True" LineHeight="14"/>
                        <TextBlock Text="{Binding QualityName}" Foreground="#A1A1AA" FontSize="10" Margin="0,3,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding ClassesLabel}" Foreground="#6A6A75" FontSize="9.5"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding ClassesLabel, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="FilterChipTemplate" DataType="{x:Type invModels:FilterChip}">
            <ToggleButton Style="{StaticResource FilterChipStyle}"
                          Content="{Binding Label}"
                          IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
        </DataTemplate>

    </UserControl.Resources>

    <Grid Background="#0F0F14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#13131A" BorderBrush="#22222A" BorderThickness="0,0,0,1" Padding="22,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Inventory" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Browse and filter your TF2 backpack." Foreground="#8C8C97" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource GhostButtonStyle}"
                            Content="{Binding Filters.SortLabel}"
                            Command="{Binding CycleSortCommand}"
                            Margin="0,0,8,0"/>
                    <Button Style="{StaticResource GhostButtonStyle}" Content="Filters"
                            Command="{Binding ToggleFiltersCommand}"
                            Margin="0,0,8,0"/>
                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="Refresh"
                            Command="{Binding RefreshCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Filter rail -->
            <Border Grid.Column="0" Width="264" Background="#0D0D12"
                    BorderBrush="#1E1E26" BorderThickness="0,0,1,0"
                    Visibility="{Binding IsFilterPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Style="{StaticResource ModernScrollViewerStyle}"
                              Padding="14,14,10,14">
                    <StackPanel>

                        <Grid Margin="0,0,0,10">
                            <TextBox x:Name="SearchBox" Style="{StaticResource SearchBoxStyle}"
                                     Text="{Binding Filters.SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Search items..." Foreground="#5A5A65" FontSize="13"
                                       IsHitTestVisible="False" VerticalAlignment="Center" Margin="12,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Filters.SearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Button Style="{StaticResource GhostButtonStyle}"
                                Content="Clear all filters" Command="{Binding ClearFiltersCommand}"
                                HorizontalAlignment="Stretch" Margin="0,2,0,14"/>

                        <StackPanel Visibility="{Binding HasItems, Converter={StaticResource BooleanToVisibilityConverter}}">

                            <TextBlock Text="CLASS" Style="{StaticResource FilterLabelStyle}"/>
                            <ItemsControl ItemsSource="{Binding Filters.Classes}" ItemTemplate="{StaticResource FilterChipTemplate}" Margin="0,0,0,12">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <TextBlock Text="ITEM TYPE" Style="{StaticResource FilterLabelStyle}"/>
                            <ItemsControl ItemsSource="{Binding Filters.ItemTypes}" ItemTemplate="{StaticResource FilterChipTemplate}" Margin="0,0,0,12">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <TextBlock Text="SLOT" Style="{StaticResource FilterLabelStyle}"/>
                            <ItemsControl ItemsSource="{Binding Filters.Slots}" ItemTemplate="{StaticResource FilterChipTemplate}" Margin="0,0,0,12">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <TextBlock Text="QUALITY" Style="{StaticResource FilterLabelStyle}"/>
                            <ItemsControl ItemsSource="{Binding Filters.Qualities}" ItemTemplate="{StaticResource FilterChipTemplate}" Margin="0,0,0,12">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <TextBlock Text="RARITY" Style="{StaticResource FilterLabelStyle}"/>
                            <ItemsControl ItemsSource="{Binding Filters.Rarities}" ItemTemplate="{StaticResource FilterChipTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Item grid + overlays -->
            <Grid Grid.Column="1">
                <ScrollViewer Style="{StaticResource ModernScrollViewerStyle}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="12,12,4,12">
                    <ItemsControl ItemsSource="{Binding Items}" ItemTemplate="{StaticResource ItemCardTemplate}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasItems}" Value="False">
                                        <Setter Property="Opacity" Value="0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HasItems}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0" To="1"
                                                                     Duration="0:0:0.28"
                                                                     DecelerationRatio="0.4"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Left"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>

                <Border Background="#CC0E0E13"
                        Visibility="{Binding HasItems, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="380">
                        <TextBlock Text="No items loaded" Foreground="#E0E0E5" FontSize="20"
                                   FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#9090A0"
                                   TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,16"/>
                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="Refresh backpack"
                                Command="{Binding RefreshCommand}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="#CC0E0E13"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ProgressBar Width="200" Height="3" IsIndeterminate="True"
                                     Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Loading inventory..." Foreground="#D0D0D5"
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Detail panel -->
            <Border Grid.Column="2" Width="352" Background="#0D0D12"
                    BorderBrush="#1E1E26" BorderThickness="1,0,0,0"
                    Visibility="{Binding IsDetailPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#11111A" BorderBrush="#22222C"
                            BorderThickness="0,0,0,1" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Item details" Foreground="White" FontWeight="SemiBold"
                                       FontSize="13" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="✕" Width="26" Height="26" Padding="0"
                                    Command="{Binding CloseDetailCommand}"
                                    Style="{StaticResource GhostButtonStyle}"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" Style="{StaticResource ModernScrollViewerStyle}" Padding="16,14">
                        <StackPanel DataContext="{Binding SelectedItem}">

                            <Border Width="140" Height="140" HorizontalAlignment="Center"
                                    Background="#11111A"
                                    BorderBrush="{Binding BorderColorHex}"
                                    BorderThickness="0,0,0,3" CornerRadius="8" Margin="0,4,0,14">
                                <Image Source="{Binding Image}" Stretch="Uniform" Margin="10"/>
                            </Border>

                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="16"
                                       FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding QualityName}" Foreground="#C0C0C8" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding TypeRaw}" Foreground="#8C8C95" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding TradableLabel}" Foreground="#8C8C95" Margin="0,2,0,14"/>

                            <Border Style="{StaticResource GlassCardStyle}" Padding="14" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Attributes" Foreground="White" FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Foreground="#B0B0B8" FontSize="12" Margin="0,2,0,0">
                                        <Run Text="Classes: " Foreground="#6C6C78"/>
                                        <Run Text="{Binding ClassesLabel}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#B0B0B8" FontSize="12" Margin="0,2,0,0"
                                               Visibility="{Binding Slot, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                                        <Run Text="Slot: " Foreground="#6C6C78"/>
                                        <Run Text="{Binding Slot}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#B0B0B8" FontSize="12" Margin="0,2,0,0">
                                        <Run Text="Rarity: " Foreground="#6C6C78"/>
                                        <Run Text="{Binding Rarity}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Margin="0,2,0,0"
                                               Visibility="{Binding UnusualEffect, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                                        <Run Text="Effect: " Foreground="#6C6C78"/>
                                        <Run Text="{Binding UnusualEffect}" Foreground="#B0B0B8"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Margin="0,2,0,0"
                                               Visibility="{Binding Paint, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                                        <Run Text="Paint: " Foreground="#6C6C78"/>
                                        <Run Text="{Binding Paint}" Foreground="#B0B0B8"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Margin="0,2,0,0"
                                               Visibility="{Binding KillstreakTier, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                                        <Run Text="Killstreak: " Foreground="#6C6C78"/>
                                        <Run Text="{Binding KillstreakTier}" Foreground="#B0B0B8"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Margin="0,2,0,0"
                                               Visibility="{Binding Spell, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                                        <Run Text="Spell: " Foreground="#6C6C78"/>
                                        <Run Text="{Binding Spell}" Foreground="#B0B0B8"/>
                                    </TextBlock>
                                    <TextBlock FontSize="12" Margin="0,2,0,0"
                                               Visibility="{Binding CraftNumber, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                                        <Run Text="Craft #: " Foreground="#6C6C78"/>
                                        <Run Text="{Binding CraftNumber}" Foreground="#B0B0B8"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Marketplace" Foreground="White" FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding DataContext.SelectedItemPrices,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#15151B" BorderBrush="#23232C"
                                                BorderThickness="1" CornerRadius="6"
                                                Padding="10" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding StoreName}" Foreground="White"
                                                               FontWeight="SemiBold" FontSize="12"/>
                                                    <TextBlock Text="{Binding Status}" Foreground="#9C9CA3"
                                                               FontSize="11" Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding PriceKeys}" Foreground="#D0D0D8"
                                                               FontSize="11"/>
                                                    <TextBlock Text="{Binding PriceRef}" Foreground="#D0D0D8"
                                                               FontSize="11"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <ProgressBar Width="32" Height="2" IsIndeterminate="True"
                                                                 Foreground="{StaticResource AccentBrush}"
                                                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    <Button Content="↗" Margin="6,0,0,0" Padding="8,3"
                                                            Command="{Binding DataContext.OpenStoreLinkCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding ListingUrl}"
                                                            Style="{StaticResource GhostButtonStyle}"
                                                            Visibility="{Binding HasListingUrl, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
