<UserControl x:Class="LauncherTF2.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1030">
    <UserControl.Resources>
        <Style x:Key="TabSwitchButtonBase" TargetType="Button">
            <Setter Property="Background" Value="#1B1B1F"/>
            <Setter Property="Foreground" Value="#B8B8C2"/>
            <Setter Property="BorderBrush" Value="#2F2F36"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#23232A"/>
                    <Setter Property="BorderBrush" Value="#43434D"/>
                    <Setter Property="Foreground" Value="#ECECF2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Margin="10,10,10,10" Background="#141418" BorderBrush="#2A2A2F" BorderThickness="1" CornerRadius="12" Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#17171C" BorderBrush="#2D2D34" BorderThickness="1" CornerRadius="10" Padding="6" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Inventory" Command="{Binding SwitchToBackpackTabCommand}" Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabSwitchButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBackpackTabActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Loadout.tf" Command="{Binding SwitchToLoadoutTabCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TabSwitchButtonBase}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoadoutTabActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid Visibility="{Binding IsBackpackTabActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#18181B" BorderBrush="#2C2C31" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,4,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                                <TextBlock Text="Inventory" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="Select any item to inspect details and live store prices." Foreground="#8A8A90" Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Sort" Command="{Binding ToggleSortCommand}"
                                        Background="#20242D" Foreground="#D9E2EE" BorderBrush="#364255"
                                        FontWeight="SemiBold" Padding="12,5" Margin="0,0,8,0" MinHeight="30"/>
                                <Button Content="Filter" Command="{Binding ToggleFilterPanelCommand}"
                                        Background="#20242D" Foreground="#D9E2EE" BorderBrush="#364255"
                                        FontWeight="SemiBold" Padding="12,5" Margin="0,0,8,0" MinHeight="30"/>
                                <Button Content="Refresh Backpack" Command="{Binding RefreshBackpackCommand}"
                                        Background="{StaticResource AccentBrush}" Foreground="White" BorderBrush="{StaticResource AccentBrush}"
                                        FontWeight="SemiBold" Padding="12,5" MinHeight="30"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                        <Border Grid.Row="1" Background="#2A2F3A" BorderBrush="#3A4250" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8"
                            Visibility="{Binding IsFilterPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Row="0" Grid.Column="0" Margin="0,0,6,8" ItemsSource="{Binding ClassFilterOptions}" SelectedItem="{Binding SelectedClassFilter}"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" Margin="6,0,0,8" ItemsSource="{Binding CollectionFilterOptions}" SelectedItem="{Binding SelectedCollectionFilter}"/>

                            <ComboBox Grid.Row="1" Grid.Column="0" Margin="0,0,6,8" ItemsSource="{Binding ExteriorFilterOptions}" SelectedItem="{Binding SelectedExteriorFilter}"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Margin="6,0,0,8" ItemsSource="{Binding QualityFilterOptions}" SelectedItem="{Binding SelectedQualityFilter}"/>

                            <ComboBox Grid.Row="2" Grid.Column="0" Margin="0,0,6,8" ItemsSource="{Binding GradeFilterOptions}" SelectedItem="{Binding SelectedGradeFilter}"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Margin="6,0,0,8" ItemsSource="{Binding TypeFilterOptions}" SelectedItem="{Binding SelectedTypeFilter}"/>

                            <Grid Grid.Row="3" Grid.ColumnSpan="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="$" Foreground="#DCE6F2" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Slider Grid.Column="1" Minimum="0" Maximum="10000" Value="{Binding MinPriceFilter}" Margin="0,0,8,0"/>
                                <Slider Grid.Column="2" Minimum="0" Maximum="10000" Value="{Binding MaxPriceFilter}" Width="180" Margin="0,0,8,0"/>
                                <Button Grid.Column="3" Content="Clear" Command="{Binding ClearFiltersCommand}" Padding="10,4" Background="#1C1F27" Foreground="#E1E7EF" BorderBrush="#394455"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="6" Background="#101010" Margin="0,0,8,0">
                            <Grid>
                                <ScrollViewer x:Name="BackpackScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Style="{StaticResource ModernScrollViewerStyle}" SizeChanged="BackpackScrollViewer_SizeChanged">
                                    <ItemsControl ItemsSource="{Binding BackpackItems}" Margin="8"
                                                  Width="{Binding ElementName=BackpackScrollViewer, Path=ViewportWidth}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel HorizontalAlignment="Center"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding DataContext.SelectItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"
                                                        Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                                                    <Border Width="{Binding DataContext.InventoryCardWidth, RelativeSource={RelativeSource AncestorType=UserControl}}" Margin="4" Padding="6" Background="#171717" BorderThickness="2" BorderBrush="{Binding BorderColorHex}" CornerRadius="8">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <Grid>
                                                                <Border Width="96" Height="96" HorizontalAlignment="Center" Background="#111" CornerRadius="6" BorderBrush="#2A2A2A" BorderThickness="1">
                                                                    <Image Source="{Binding ImageUrl}" Width="96" Height="96" Stretch="UniformToFill"/>
                                                                </Border>

                                                                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Padding="5,2" Background="#CC6B1B1B" CornerRadius="8" Margin="0,2,2,0"
                                                                        Visibility="{Binding IsEquipped, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                    <TextBlock Text="Equipped" FontSize="9" Foreground="White" FontWeight="SemiBold"/>
                                                                </Border>
                                                            </Grid>

                                                            <TextBlock Grid.Row="1" Margin="0,6,0,2" Text="{Binding Name}" Foreground="White" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="30"/>
                                                            <StackPanel Grid.Row="2">
                                                                <TextBlock Text="{Binding QualityName}" Foreground="#BBB" FontSize="10"/>
                                                                <TextBlock Text="{Binding Type}" Foreground="#888" FontSize="9" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding PricePureLabel}" Foreground="#8BC34A" FontSize="10" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <Border Background="#CC0E0E10" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <ProgressBar Width="220" Height="6" IsIndeterminate="True" Foreground="{StaticResource AccentBrush}"/>
                                        <TextBlock Text="Loading inventory..." Foreground="#D0D0D5" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="#BB0E0E10" Visibility="{Binding HasBackpackItems, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
                                        <TextBlock Text="No items loaded yet" Foreground="#D0D0D5" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Click Refresh Backpack to load your inventory." Foreground="#9898A0" TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Width="{Binding DetailPanelWidth}" Visibility="{Binding IsDetailPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                                BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="6" Background="#121216">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#1A1A1F" BorderBrush="#2D2D33" BorderThickness="0,0,0,1" Padding="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" Width="28" Height="28" Command="{Binding ToggleDetailPanelCommand}" Content="{Binding DetailPanelToggleGlyph}"
                                                Background="#111114" Foreground="{StaticResource AccentBrush}" BorderBrush="#303036" BorderThickness="1"/>

                                        <TextBlock Grid.Column="1" Text="Item Details" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"
                                                   Visibility="{Binding IsDetailPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                        <Button Grid.Column="2" Width="28" Height="28" Command="{Binding CloseDetailPanelCommand}" Content="X"
                                                Background="#111114" Foreground="#B0B0B8" BorderBrush="#303036" BorderThickness="1"
                                                Visibility="{Binding IsDetailPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="1" Margin="8">
                                    <Grid Visibility="{Binding IsDetailPanelExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource ModernScrollViewerStyle}">
                                            <StackPanel>
                                                <Border Width="140" Height="140" HorizontalAlignment="Center" Background="#111" CornerRadius="8" BorderBrush="#2A2A2A" BorderThickness="1" Margin="0,2,0,8">
                                                    <Image Source="{Binding SelectedItem.ImageUrl}" Stretch="UniformToFill"/>
                                                </Border>

                                                <TextBlock Text="{Binding SelectedItem.Name}" Foreground="White" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding SelectedItem.QualityName}" Foreground="#BBB" Margin="0,4,0,0"/>
                                                <TextBlock Text="{Binding SelectedItem.Type}" Foreground="#8E8E96" Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding SelectedItem.TradableLabel}" Foreground="#8E8E96" Margin="0,2,0,0"/>

                                                <Separator Margin="0,10,0,10"/>

                                                <TextBlock Text="Attributes" Foreground="White" FontWeight="SemiBold"/>
                                                <TextBlock Foreground="#B8B8C0" Margin="0,4,0,0"><Run Text="Rarity: "/><Run Text="{Binding SelectedItem.Rarity}"/></TextBlock>
                                                <TextBlock Foreground="#B8B8C0" Margin="0,2,0,0"><Run Text="Unusual Effect: "/><Run Text="{Binding SelectedItem.UnusualEffect}"/></TextBlock>
                                                <TextBlock Foreground="#B8B8C0" Margin="0,2,0,0"><Run Text="Paint: "/><Run Text="{Binding SelectedItem.Paint}"/></TextBlock>
                                                <TextBlock Foreground="#B8B8C0" Margin="0,2,0,0"><Run Text="Killstreak Tier: "/><Run Text="{Binding SelectedItem.KillstreakTier}"/></TextBlock>
                                                <TextBlock Foreground="#B8B8C0" Margin="0,2,0,0"><Run Text="Sheen: "/><Run Text="{Binding SelectedItem.KillstreakSheen}"/></TextBlock>
                                                <TextBlock Foreground="#B8B8C0" Margin="0,2,0,0"><Run Text="Killstreaker: "/><Run Text="{Binding SelectedItem.Killstreaker}"/></TextBlock>
                                                <TextBlock Foreground="#B8B8C0" Margin="0,2,0,0"><Run Text="Spell: "/><Run Text="{Binding SelectedItem.Spell}"/></TextBlock>
                                                <TextBlock Foreground="#B8B8C0" Margin="0,2,0,0"><Run Text="Craft #: "/><Run Text="{Binding SelectedItem.CraftNumber}"/></TextBlock>
                                                <TextBlock Foreground="#B8B8C0" Margin="0,2,0,0"><Run Text="Equipped On: "/><Run Text="{Binding SelectedItem.EquippedOn}"/></TextBlock>

                                                <Separator Margin="0,10,0,10"/>

                                                <TextBlock Text="Prices" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,6"/>

                                                <ItemsControl ItemsSource="{Binding SelectedItemStorePrices}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#19191D" BorderBrush="#2B2B31" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <StackPanel Grid.Column="0">
                                                                        <TextBlock Text="{Binding StoreName}" Foreground="White" FontWeight="SemiBold"/>
                                                                        <TextBlock Text="{Binding Status}" Foreground="#9C9CA3" FontSize="11" Margin="0,2,0,0"/>
                                                                        <TextBlock Text="{Binding PriceKeys}" Foreground="#D0D0D8" FontSize="11" Margin="0,2,0,0"/>
                                                                        <TextBlock Text="{Binding PriceRef}" Foreground="#D0D0D8" FontSize="11"/>
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                                        <ProgressBar Width="48" Height="4" IsIndeterminate="True" Foreground="{StaticResource AccentBrush}"
                                                                                     Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                        <Button Content="↗" Command="{Binding DataContext.OpenStoreLinkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                CommandParameter="{Binding ListingUrl}" Margin="8,0,0,0" Padding="8,3"
                                                                                Visibility="{Binding HasListingUrl, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                                Background="#1D2933" Foreground="#D8ECFF" BorderBrush="#2F4D66"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>

                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0"
                                                Visibility="{Binding IsDetailPanelExpanded, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <Border Width="64" Height="64" Background="#111" CornerRadius="6" BorderBrush="#2A2A2A" BorderThickness="1">
                                            <Image Source="{Binding SelectedItem.ImageUrl}" Stretch="UniformToFill"/>
                                        </Border>
                                        <TextBlock Text="{Binding SelectedItem.Name}" Foreground="#DDD" FontSize="10" TextWrapping="Wrap" TextAlignment="Center" Width="72" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Visibility="{Binding IsLoadoutTabActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Background="#101014" BorderBrush="#2A2A2F" BorderThickness="1" CornerRadius="8" Padding="8">
                        <wpf:WebView2 x:Name="LoadoutBrowser" Margin="0"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
