<Window x:Class="LauncherTF2.Views.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message" Height="200" Width="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="14"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>

        <Grid Margin="28,24,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Icon + Title -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
                <!-- Icon -->
                <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource SurfaceInsetBrush}"
                        Margin="0,0,12,0" VerticalAlignment="Center">
                    <Path x:Name="IconPath" Fill="{DynamicResource AccentBrush}" Data="M12 2L1 21h22L12 2zm0 3.5L20.5 19h-17L12 5.5zm-1 5v5h2v-5h-2zm0 6v2h2v-2h-2z"
                          Stretch="Uniform" Width="16" Height="16"/>
                </Border>
                <TextBlock x:Name="TitleText" Text="Message"
                           Foreground="{DynamicResource TextBrush}" FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI"/>
            </StackPanel>

            <!-- Message -->
            <TextBlock Grid.Row="1" x:Name="MessageText"
                       Foreground="{DynamicResource SecondaryTextBrush}" FontSize="13"
                       TextWrapping="Wrap" LineHeight="20"
                       FontFamily="Segoe UI"
                       VerticalAlignment="Center"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,18,0,0"
                        VerticalAlignment="Bottom">

                <!-- Cancel (Optional) -->
                <Button x:Name="CancelButton" Content="Cancel"
                        Width="90" Height="34" Margin="0,0,10,0"
                        Cursor="Hand" Click="CancelButton_Click"
                        Visibility="Collapsed"
                        Foreground="{DynamicResource SecondaryTextBrush}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="{DynamicResource SurfaceAltBrush}" CornerRadius="8"
                                    BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="{DynamicResource SurfaceInsetBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>

                    <Button.FontFamily>
                        <FontFamily>Segoe UI</FontFamily>
                    </Button.FontFamily>
                    <Button.FontSize>13</Button.FontSize>
                </Button>

                <!-- OK / Confirm -->
                <Button x:Name="OkButton" Content="OK"
                        Width="90" Height="34"
                        Cursor="Hand" Click="OkButton_Click"
                        Foreground="{DynamicResource AccentForegroundBrush}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="{DynamicResource AccentBrush}" CornerRadius="8"
                                    BorderThickness="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bg" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>

                    <Button.FontFamily>
                        <FontFamily>Segoe UI</FontFamily>
                    </Button.FontFamily>
                    <Button.FontSize>13</Button.FontSize>
                    <Button.FontWeight>SemiBold</Button.FontWeight>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
