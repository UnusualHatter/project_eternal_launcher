## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET build artifacts
artifacts/
*.nupkg
*.snupkg

# Visual Studio 2015/2017 cache/options directory
.vs/

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# System Files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*$py.class
*.spec
*.manifest

# Virtual/Anaconda Environments
venv/
env/
ENV/

# Logs
*.log
*_debug*.txt
build_*.txt
debug_*.txt

# Runtime-generated cache & data files
*_cache.json
settings.json
launcher_config.json
mod_state.json

# Downloaded mod thumbnails (fetched at runtime from GameBanana)
mod_thumbnails/

# Temporary / test files
api_test.json
temp_*.json
temp_*.txt
